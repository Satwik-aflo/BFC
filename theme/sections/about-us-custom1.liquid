{% comment %}
  Custom "About Us" Section
  - Matches the design with Purple Blob, Patna Sign, and Sparkles.
{% endcomment %}

<section class="about-us-section about-us-{{ section.id }}">
  <div class="about-us-container">
    
    <div class="about-us-top">
      {% if section.settings.heading != blank %}
        <h2 class="about-us-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      <div class="about-us-blob-wrapper">
        {% if section.settings.blob_image != blank %}
          {{ section.settings.blob_image | image_url: width: 1200 | image_tag: class: 'blob-bg', loading: 'lazy' }}
        {% endif %}

        {% if section.settings.sparkle_image != blank %}
          <div class="sparkle sparkle-left">
            {{ section.settings.sparkle_image | image_url: width: 100 | image_tag: loading: 'lazy' }}
          </div>
        {% endif %}

        <div class="blob-content">
          {{ section.settings.blob_text }}
        </div>

        {% if section.settings.sparkle_image != blank %}
          <div class="sparkle sparkle-right">
            {{ section.settings.sparkle_image | image_url: width: 100 | image_tag: loading: 'lazy' }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="about-us-bottom">
      
      <div class="sign-wrapper">
        {% if section.settings.sign_image != blank %}
          {{ section.settings.sign_image | image_url: width: 600 | image_tag: class: 'sign-image', loading: 'lazy' }}
        {% endif %}
      </div>

      <div class="bottom-text-wrapper">
        <div class="bottom-text">
          {{ section.settings.bottom_text }}
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  /* Scoped Variables */
  .about-us-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 10px 20px;
    position: relative;
    overflow: hidden;
    padding-top: 60px;
    padding-Bottom: 0;
  }

  .about-us-container {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  /* --- TOP SECTION --- */
  .about-us-top {
    position: relative;
    margin-bottom: 10px;
  }

  .about-us-heading {
    font-family: flagfies-regular !important; /* Swap for your theme font */
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    text-transform: uppercase;
    line-height: 1;
    margin: 0 0 20px 0;
    position: absolute; /* Position top-left */
    top: 0;
    z-index: 2;

  }

  /* Blob Container */
  .about-us-blob-wrapper {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
    min-height: 400px;
    display: flex;
    justify-content: center;
    text-align: center;
    padding: 80px 60px;
    align-items: center;
    margin-top: 40px;
}

  /* The Purple Blob Image */
  .blob-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: fill; /* Stretch to cover wrapper */
    z-index: 0;
  }

  /* The Text inside the Blob */
  .blob-content {
    position: relative;
    z-index: 1;
    color: {{ section.settings.blob_text_color }};
    font-size: 20px;
    line-height: 1.4;
    max-width: 600px;
    text-align: left;
  
  }
  
  .blob-content strong {
    font-weight: 800;
  }

  /* Sparkles */
  .sparkle {
    position: absolute;
    width: 80px;
    height: auto;
    z-index: 2;
  }

  .sparkle-left {
    left: -15px;
    top: 50%;
    transform: translateY(-50%);
  }

  .sparkle-right {
    right: -20px;
    top: 50%;
    transform: translateY(-50%);
  }

  /* --- BOTTOM SECTION --- */
  .about-us-bottom {
    display: flex;
    align-items: flex-start; /* Align top */
    justify-content: space-between;
    gap: 0px;
    margin-top: -40px; /* Pull up closer to blob */
    padding-left: 0px;
    padding-right: 20px;
  }

  .sign-wrapper {
    flex: 0 0 250px; /* Fixed width for sign */
  }

  .sign-image {
    width: auto;
    height: 13rem;
    display: block;
    /*transform: rotate(-2deg);  Slight tilt like image */
  }

  .bottom-text-wrapper {
    flex: 1;
    padding-top: 40px; /* Align text nicely with sign */
  }

  .bottom-text {
    font-size: 20px;
    margin-top: 20px;
    line-height: 1.4;
    color: {{ section.settings.bottom_text_color }};
    padding-right: 90px;
  }

  .bottom-text strong {
    color: {{ section.settings.blob_bg_color }}; /* Use purple for bold text */
    font-weight: 700;
  }

  /* --- RESPONSIVE --- */
  /* =====================================
   MOBILE FIX — ABOUT US SECTION
   ===================================== */
  @media (max-width: 768px) {

    /* General safety */
    .about-us-{{ section.id }} {
      padding-top: 12px;
      padding-left: 12px;
      padding-right: 12px;
    }

    .about-us-container {
      max-width: 100%;
      overflow-x: hidden;
    }

    /* ---------- Heading ---------- */
    .about-us-heading {
      position: relative;
      top: auto;
      left: auto;
      text-align: center;
      font-size: 32px;
      line-height: 1.1;
      margin-bottom: 16px;
    }

    /* ---------- Blob Section ---------- */
    .about-us-blob-wrapper {
      max-width: 100%;
      margin-top: 0;
      padding: 36px 20px;
      min-height: auto;
    }

    .blob-bg {
      object-fit: cover;
    }

    .blob-content {
      font-size: 14px;
      line-height: 1.2;
      text-align: center;
      max-width: 100%;
    }

    /* Hide sparkles on mobile (prevents overflow) */
    .sparkle {
      display: none;
    }

    /* ---------- Bottom Section ---------- */
    .about-us-bottom {
      flex-direction: row;
      align-items: center;
      margin-top: 6px;
      padding-right: 0;
      gap: 16px;
      text-align: left;
    }

    .sign-wrapper {
      width: auto;
      max-width: 100px;
    }

    .sign-image {
      height: auto;
      max-height: 140px;
      width: 100%;
    }

    .bottom-text-wrapper {
      padding-top: 0;
      width: 100%;
    }

    .bottom-text {
      font-size: 14px;
      line-height: 1.3;
      padding-right: 0;
      margin-top: 0;
      text-align: left;
    }
  }

</style>

{% schema %}
{
  "name": "About Us (Custom)",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FBF3CC"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#FF4D1C"
    },
    {
      "type": "color",
      "id": "blob_bg_color",
      "label": "Blob Color (Used for bottom bold text)",
      "default": "#5A56B3"
    },
    {
      "type": "color",
      "id": "blob_text_color",
      "label": "Blob Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "bottom_text_color",
      "label": "Bottom Text Color",
      "default": "#6A6AF0"
    },
    {
      "type": "header",
      "content": "Top Section"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ABOUT US"
    },
    {
      "type": "image_picker",
      "id": "blob_image",
      "label": "Purple Blob Background Image"
    },
    {
      "type": "richtext",
      "id": "blob_text",
      "label": "Blob Text",
      "default": "<p>We started The Boring Foods Company because we were deeply confused about health and wellness ourselves.</p>"
    },
    {
      "type": "image_picker",
      "id": "sparkle_image",
      "label": "Sparkle Icon (Orange Star)"
    },
    {
      "type": "header",
      "content": "Bottom Section"
    },
    {
      "type": "image_picker",
      "id": "sign_image",
      "label": "Patna Sign Image"
    },
    {
      "type": "richtext",
      "id": "bottom_text",
      "label": "Bottom Text",
      "default": "<p>It’s how we met in 2019...</p>"
    }
  ],
  "presets": [
    {
      "name": "About Us (Custom)"
    }
  ]
}
{% endschema %}