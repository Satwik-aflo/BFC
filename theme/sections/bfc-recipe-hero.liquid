<section
  class="recipe-hero color-{{ section.settings.color_scheme }} recipe-hero--{{ section.id }}"
  style="--rh-pad-top: {{ section.settings.padding_top }}px; --rh-pad-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="recipe-hero__inner">
    {%- if section.settings.kicker != blank -%}
      <span class="recipe-hero__kicker">{{ section.settings.kicker | escape }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="recipe-hero__title">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}
    {%- if section.settings.intro != blank -%}
      <div class="recipe-hero__intro">{{ section.settings.intro }}</div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .recipe-hero {
    padding-block: var(--rh-pad-top, 64px) var(--rh-pad-bottom, 32px);
    padding-inline: 5vw;
    text-align: center;
  }

  .recipe-hero__inner {
    max-width: 60rem;
    margin-inline: auto;
  }

  .recipe-hero__kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.85em;
    font-family: var(--font-heading--family);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.875rem;
  }

  .recipe-hero__kicker::before,
  .recipe-hero__kicker::after {
    content: "";
    width: 2.5rem;
    height: 1px;
    background: currentColor;
    opacity: 0.5;
  }

  .recipe-hero__title {
    font-family: var(--font-heading--family);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    /* Smaller than the static text-3xl for mobile legibility */
    font-size: clamp(2rem, 1.4rem + 3vw, 3.5rem);
    line-height: 1.05;
    margin-block: 0.6rem 0;
    color: #244f24;
    overflow-wrap: break-word;
    hyphens: auto;
  }

  .recipe-hero__intro {
    font-family: var(--font-body--family);
    font-size: 1.125rem;
    line-height: 1.6;
    max-width: 44rem;
    margin: 1rem auto 0;
    opacity: 0.9;
  }

  .recipe-hero__intro p {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Recipe hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Recipe Guide"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Simple Ways to Use Power-Packed Ingredients"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Boring staples, anything-but-boring in the glass. Easy, everyday ways to get turmeric, moringa, and ashwagandha into your routine — no chef skills required.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Recipe hero"
    }
  ]
}
{% endschema %}
