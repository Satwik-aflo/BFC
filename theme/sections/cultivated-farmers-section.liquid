<style>
        .turmeric-story-section {
            --color-primary: #78350F;
            --color-primary-dark: #2563eb;
            --color-text: #78350F;
            --color-text-light: #78350F;
            --color-bg-light: #FBF3CC;
            --color-white: #ffffff;
            --color-accent: #10b981;
            --spacing-sm: 1rem;
            --spacing-md: 2rem;
            --spacing-lg: 3rem;
            --spacing-xl: 4rem;
        }

        .turmeric-story-section * {
            box-sizing: border-box;
        }

        .turmeric-story-section {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            line-height: 1.6;
        }

        .turmeric-story-section {
            background: linear-gradient(to bottom, #ffffff 0%, #FBF3CC 100%);
            padding: var(--spacing-xl) var(--spacing-md);
            position: relative;
        }

        .turmeric-story-section .story-container {
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
        }

        .story-header {
            text-align: center;
            margin-bottom: var(--spacing-xl);
        }

        .story-title {
            font-size: clamp(2rem, 4vw, 3rem);
            color: var(--color-primary);
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 0.5rem;
        }

        .story-subtitle {
            font-size: clamp(1.5rem, 3vw, 2.5rem);
            color: var(--color-primary);
            font-weight: 700;
            line-height: 1.2;
        }

        .story-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--spacing-lg);
            align-items: center;
            margin-top: var(--spacing-xl);
        }

        .story-image-container {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .image-frame {
            position: relative;
            width: 100%;
            max-width: 600px;
        }

        .frame-background {
            position: absolute;
            top: -20px;
            left: -20px;
            width: 100%;
            height: 100%;
            background-color: var(--color-primary);
            border-radius: 8px;
            z-index: 1;
        }

        .main-image {
            position: relative;
            z-index: 2;
            width: 100%;
            height: auto;
            border-radius: 8px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
            background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
            aspect-ratio: 16/10;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
        }

        .main-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 8px;
        }

        .refer-badge {
            position: absolute;
            bottom: 20px;
            left: 20px;
            background-color: var(--color-accent);
            color: var(--color-white);
            padding: 0.75rem 1.5rem;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.95rem;
            z-index: 3;
            box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
            transition: transform 0.3s ease;
        }

        .refer-badge:hover {
            transform: scale(1.05);
        }

        .story-text {
            padding: var(--spacing-md);
        }

        .story-description {
            font-size: 1.1rem;
            color: var(--color-text-light);
            line-height: 1.8;
            margin-bottom: var(--spacing-md);
        }

        .cta-button {
            display: inline-block;
            padding: 1rem 2.5rem;
            background-color: transparent;
            color: var(--color-primary);
            border: 2px solid var(--color-primary);
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .cta-button:hover {
            background-color: var(--color-primary);
            color: var(--color-white);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(59, 130, 246, 0.3);
        }

        /* Decorative elements */
        .turmeric-story-section::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            z-index: 0;
        }

        .turmeric-story-section::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(16, 185, 129, 0.08) 0%, transparent 70%);
            border-radius: 50%;
            z-index: 0;
        }

        .turmeric-story-section .story-container {
            position: relative;
            z-index: 1;
        }

        @media (max-width: 968px) {
            .story-content {
                grid-template-columns: 1fr;
                gap: var(--spacing-md);
            }

            .story-image-container {
                order: 1;
            }

            .story-text {
                order: 2;
                text-align: center;
                padding: var(--spacing-sm);
            }

            .frame-background {
                top: -15px;
                left: -15px;
            }

            .main-image {
                font-size: 3rem;
            }
        }

        @media (max-width: 640px) {
            .turmeric-story-section {
                padding: var(--spacing-lg) var(--spacing-sm);
            }

            .story-title,
            .story-subtitle {
                font-size: 1.75rem;
            }

            .story-description {
                font-size: 1rem;
            }

            .cta-button {
                padding: 0.875rem 2rem;
                font-size: 0.95rem;
            }

            .main-image {
                font-size: 2rem;
            }
        }
</style>

<section class="turmeric-story-section"> 
    <div class="story-container">
        <div class="story-header">
            <h2 class="story-title">
              {{ section.settings.title_line1 }}
            </h2>
            <h2 class="story-subtitle">
              {{ section.settings.title_line2 }}
            </h2>
        </div>

        <div class="story-content">
            <div class="story-image-container">
                <div class="image-frame">
                    <div class="frame-background"></div>
                    <div class="main-image">
                        {% if section.settings.image != blank %}
                            <img src="{{ section.settings.image | img_url: '1200x' }}" alt="{{ section.settings.image_alt | escape }}">
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="story-text">
                <p class="story-description">
                    {{ section.settings.description }}
                </p>
                
                {% if section.settings.button_text != blank %}
                  <a href="{{ section.settings.button_link }}" class="cta-button">
                      {{ section.settings.button_text }}
                  </a>
                {% endif %}
            </div>
        </div>
    </div>
</section>

<script>
        // Smooth scroll functionality
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Intersection Observer for fade-in animation
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -100px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, observerOptions);

        // Add animation styles
        const animatedElements = document.querySelectorAll('.story-image-container, .story-text');
        animatedElements.forEach(el => {
            el.style.opacity = '0';
            el.style.transform = 'translateY(30px)';
            el.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
            observer.observe(el);
        });
</script>

{% schema %}
{
  "name": "Turmeric story section",
  "settings": [
    {
      "type": "text",
      "id": "title_line1",
      "label": "Title line 1",
      "default": "Cultivated by Farmers,"
    },
    {
      "type": "text",
      "id": "title_line2",
      "label": "Title line 2",
      "default": "Backed by Nature."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Story description",
      "default": "As passionate farmers dedicated to sustainable agriculture, we were inspired to share the incredible healing properties of turmeric with the world..."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Turmeric story image"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Read Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Turmeric story section"
    }
  ]
}
{% endschema %}
