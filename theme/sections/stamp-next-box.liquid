{% comment %}
  Custom "Stamp Text" Section (Final Mobile Fix)
  - Desktop: Purple Stamp Image + White Text + Shadow.
  - Mobile: Clean Layout (No Image) + #6A6AF0 Text.
{% endcomment %}

<section class="stamp-section stamp-section-{{ section.id }}">
  <div class="stamp-container">
    
    <div class="stamp-header">
      {% if section.settings.icon_image != blank %}
        <div class="stamp-icon">
          {{ section.settings.icon_image | image_url: width: 100 | image_tag: loading: 'lazy' }}
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="stamp-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.icon_image != blank %}
        <div class="stamp-icon">
          {{ section.settings.icon_image | image_url: width: 100 | image_tag: loading: 'lazy' }}
        </div>
      {% endif %}
    </div>

    <div class="stamp-box-wrapper">
      
      <div class="stamp-bg-layer"></div>

      <div class="stamp-content-layer">
        <div class="stamp-text-inner">
          {{ section.settings.text_content }}
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  /* --- GLOBAL VARIABLES --- */
  .stamp-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 20px 20px;
    font-family: serif; 
    overflow: hidden;
    padding-bottom: 40px;
  }

  .stamp-container {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* --- HEADER --- */
  .stamp-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 0px;
  }

  .stamp-heading {
    color: {{ section.settings.heading_color }};
    font-size: clamp(24px, 5vw, 29px);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
    line-height: 1.2;
    font-family: OPTICopperplate !important;
  }

  .stamp-icon img {
    width: 60px;
    height: auto;
    display: block;
  }

  /* --- BOX WRAPPER --- */
  .stamp-box-wrapper {
    position: relative;
    display: inline-block;
    width: 100%;
    max-width: 800px;
    width: 759.887px;
    height: 299.81px;
    margin-top: 10px;

  }

  /* --- LAYER 1: BACKGROUND + SHADOW --- */
  .stamp-bg-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1; 

    {% if section.settings.stamp_bg_image != blank %}
      background-image: url({{ section.settings.stamp_bg_image | image_url: width: 1200 }});
    {% else %}
      background-color: {{ section.settings.box_color }};
      border-radius: 12px;
    {% endif %}

    background-size: 100% 100%; 
    background-repeat: no-repeat;
    background-position: center;

    /* Drop shadow on the background layer */
    filter: drop-shadow(20px 20px 0px {{ section.settings.shadow_color }});
  }

  /* --- LAYER 2: CONTENT --- */
  .stamp-content-layer {
    position: relative;
    z-index: 2; 
    width: 100%;
    color: {{ section.settings.text_color }};
    text-shadow: none !important; 
  }

  /* --- TEXT STYLES --- */
  .stamp-text-inner {
    font-size: 20px;
    line-height: 1.6;
    font-family: Aesthet-Nova !important;
    padding-top: 2rem;
  }

  .stamp-text-inner p {
      margin-bottom: 24px;
      padding: 0px 80px;
      text-align: left;
  }
  .stamp-text-inner p:last-child {
    margin-bottom: 0;
  }

  .stamp-text-inner strong {
    font-weight: 800;
    display: block; 
    margin: 20px 0;
    font-size: 20px;
  }

  /* --- MOBILE RESPONSIVENESS (Max-width 768px) --- */
  /* =====================================
   FINAL MOBILE FIX — STAMP SECTION
   ===================================== */
@media (max-width: 768px) {

  /* Section spacing */
  .stamp-section-{{ section.id }} {
    padding: 12px 12px 12px;
    padding-bottom: 0px;
  }

  /* Header tightening */
  .stamp-header {
    gap: 8px;
    margin-bottom: 12px;
  }

  .stamp-heading {
    font-size: 22px;
    line-height: 1.2;
  }

  /* 🔥 CRITICAL: remove fixed box sizing */
  .stamp-box-wrapper {
    width: 100% !important;
    max-width: 100% !important;
    height: auto !important;
    margin-top: 0;
  }

  /* Background already hidden — ensure no shadow space */
  .stamp-bg-layer {
    display: none !important;
  }

  /* Content reset */
  .stamp-content-layer {
    width: 100%;
    color: #6A6AF0 !important;
  }

  /* Text sizing & spacing */
  .stamp-text-inner {
    font-size: 14px;
    line-height: 1.3;
    padding-top: 0;
  }

  /* 🔥 Remove desktop side padding + center text */
  .stamp-text-inner p {
    padding: 0 !important;
    margin-bottom: 16px;
    text-align: center;
  }

  .stamp-text-inner strong {
    font-size: 14px;
    margin: 14px 0;
    text-align: center;
  }
}

  }
</style>

{% schema %}
{
  "name": "Stamp Text (Final)",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#FBF3CC"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#EC4C22"
    },
    {
      "type": "color",
      "id": "shadow_color",
      "label": "Shadow Color (Desktop Only)",
      "default": "#FFC62F"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color (Desktop Only)",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "box_color",
      "label": "Fallback Box Color",
      "default": "#5A56B3"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "SO WE DECIDED TO FIX IT."
    },
    {
      "type": "image_picker",
      "id": "icon_image",
      "label": "Icon (Rose)"
    },
    {
      "type": "header",
      "content": "Stamp Background"
    },
    {
      "type": "image_picker",
      "id": "stamp_bg_image",
      "label": "Stamp Background Image (PNG)",
      "info": "Upload your purple shape here. Use a Transparent PNG."
    },
    {
      "type": "range",
      "id": "text_padding_vertical",
      "min": 20,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Desktop Vertical Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "text_padding_horizontal",
      "min": 20,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Desktop Horizontal Padding",
      "default": 60
    },
    {
      "type": "richtext",
      "id": "text_content",
      "label": "Box Text",
      "default": "<p>we researched, tested, rejected, re-tested, and built a sourcing model that could preserve quality from soil to spoon.</p><p><strong>We didn’t want nostalgia. We wanted function.</strong></p><p>So we studied each ingredient for what it actually does...</p>"
    }
  ],
  "presets": [
    {
      "name": "Stamp Text (Final)"
    }
  ]
}
{% endschema %}