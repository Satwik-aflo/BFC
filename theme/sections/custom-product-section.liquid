<section class="superfoods-section">
  <h2 class="section-title">
    {{ section.settings.section_title }}
  </h2>

  <div class="superfoods-grid">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}
      {% if product != blank %}
        <div class="food-card" {{ block.shopify_attributes }}>
          <div
            class="food-card-header"
            style="background: {{ block.settings.header_color }};"
          >
            {{ block.settings.card_title | default: product.title }}
          </div>

          <div class="food-card-img">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | img_url: '600x' }}"
                alt="{{ product.title | escape }}"
                loading="lazy"
              >
            {% endif %}
          </div>

          <a href="{{ product.url }}" class="shop-btn">
            {{ block.settings.button_label | default: 'SHOP' }}
          </a>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% stylesheet %}
/* SUPERFOODS SECTION DESIGN */

.superfoods-section {
  padding: 60px 20px;
  text-align: center;
  font-family: Arial, sans-serif;
  background-color: #5D57C5;
}

.section-title {
  font-size: 32px;
  font-weight: 800;
  color: #F84B21;
  margin: 0px 0px 40px 40px;
}

.superfoods-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30px;
  max-width: 1300px;
  margin: auto;
}

.food-card {
  background: #FBF3CC;
  border-radius: 20px;
  padding-bottom: 30px;
  overflow: hidden;
  box-shadow: 0px 4px 14px rgba(0,0,0,0.15);
  transition: transform 0.3s ease;
}

.food-card-header {
  padding: 40px 20px 60px;
  font-size: 22px;
  font-weight: 700;
  color: #000000;
  border-bottom-left-radius: 100%;
  border-bottom-right-radius: 100%;
  text-align: center;
}

/* Image + hover zoom */
.food-card-img img {
  width: 75%;
  margin: -60px auto 20px;
  display: block;
  transition: transform 0.45s ease;
}

.food-card:hover .food-card-img img {
  transform: scale(1.04);
}

/* Button */
.shop-btn {
  display: inline-block;
  margin-top: 10px;
  background: #F9BF29;
  padding: 14px 40px;
  border-radius: 50px;
  color: #fff;
  font-weight: bold;
  font-size: 18px;
  text-decoration: none;
}

.shop-btn:hover {
  background: #F9BF29;
}

/* Responsive */
@media (max-width: 1024px) {
  .superfoods-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 600px) {
  .superfoods-grid {
    grid-template-columns: 1fr;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Boringfoods product cards",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "Superfoods Your Way"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card title",
          "info": "Leave empty to use the product title"
        },
        {
          "type": "color",
          "id": "header_color",
          "label": "Header background color",
          "default": "#4CAF50"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "SHOP"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Boringfoods product cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "card_title": "Organic Pure Moringa Powder",
            "header_color": "#4CAF50"
          }
        },
        {
          "type": "card",
          "settings": {
            "card_title": "Organic Superfood Lattes",
            "header_color": "#FFABC4"
          }
        },
        {
          "type": "card",
          "settings": {
            "card_title": "Organic Superfood Blends",
            "header_color": "#226EB5"
          }
        },
        {
          "type": "card",
          "settings": {
            "card_title": "Superfood Gummies",
            "header_color": "#A51E45"
          }
        }
      ]
    }
  ]
}
{% endschema %}
