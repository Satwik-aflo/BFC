{% comment %}
  Brand section: How to Use — numbered steps on a Neem-Green background.
  Merchant-editable via "step" blocks. Static brand copy as defaults.
{% endcomment %}

<section class="phow color-{{ section.settings.color_scheme }} section">
  <div class="phow__inner">
    <div class="phow__head">
      {%- if section.settings.kicker != blank -%}
        <span class="bfc-kicker">{{ section.settings.kicker }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="phow__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <ol class="phow__steps">
        {%- for block in section.blocks -%}
          {%- assign step_num = forloop.index -%}
          <li class="phow__step" {{ block.shopify_attributes }}>
            <span class="phow__n">
              {%- if block.settings.number != blank -%}{{ block.settings.number }}{%- else -%}{{ step_num | prepend: '0' | slice: -2, 2 }}{%- endif -%}
            </span>
            {%- if block.settings.title != blank -%}
              <h3 class="phow__step-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="phow__step-text">{{ block.settings.text }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ol>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .phow {
    /* Win over Horizon's color-{scheme} class on the same element, which
       otherwise paints the section cream (→ cream text on cream + the mango
       step number drops to 1.5:1). The section is brand-fixed neem-green. */
    background-color: var(--neem-green) !important;
    color: var(--kulfi-malai);
  }
  .phow__inner {
    max-width: 72rem;
    margin: 0 auto;
    padding-inline: var(--gutter);
  }
  .phow__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }
  .phow__title {
    font-family: var(--font-heading--family);
    font-weight: 400;
    font-size: var(--text-2xl);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.15;
    margin: 0;
    color: var(--kulfi-malai);
    overflow-wrap: break-word;
    hyphens: auto;
  }
  .phow__steps {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }
  .phow__step { text-align: center; }
  .phow__n {
    display: block;
    font-family: var(--font-heading--family);
    font-weight: 700;
    font-size: var(--text-xl);
    color: var(--mango-yellow);
  }
  .phow__step-title {
    font-family: var(--font-heading--family);
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: var(--text-base);
    margin: var(--space-1) 0;
    color: var(--kulfi-malai);
    overflow-wrap: break-word;
  }
  .phow__step-text {
    font-family: var(--font-body--family);
    font-size: var(--text-sm);
    line-height: 1.55;
    margin: 0;
    color: var(--kulfi-malai);
    opacity: 0.9;
  }
  @media (max-width: 720px) {
    .phow__steps { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product How to Use",
  "tag": "section",
  "class": "section-product-how-to-use",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-neem"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "½–1 tsp · Once Daily"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How to Use"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "info": "Leave blank to auto-number (01, 02, ...)."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Warm Milk or Water"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Stir ½–1 teaspoon (1.5–3 g) into warm milk or water for a daily golden drink."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product How to Use",
      "blocks": [
        { "type": "step", "settings": { "number": "01", "title": "Warm Milk or Water", "text": "Stir ½–1 teaspoon (1.5–3 g) into warm milk or water for a daily golden drink." } },
        { "type": "step", "settings": { "number": "02", "title": "Cook With It", "text": "Add to dals, curries, rice, and sabzis the way it's been done for generations." } },
        { "type": "step", "settings": { "number": "03", "title": "Honey + Lemon", "text": "Mix with honey and a squeeze of lemon for an easy immunity shot." } }
      ]
    }
  ]
}
{% endschema %}
