{% comment %}
  Custom Story Section
  - Matches the "Years later..." layout with text on left, image + sun sticker on right.
{% endcomment %}

<section class="story-section story-section-{{ section.id }}">
  <div class="story-container">
    
    <div class="story-text-col">
      <div class="story-body">
        {{ section.settings.main_text }}
      </div>
      
      {% if section.settings.bullet_list != blank %}
        <div class="story-list-wrapper">
          {{ section.settings.bullet_list }}
        </div>
      {% endif %}
    </div>

    <div class="story-image-col">
      <div class="story-image-wrapper">
        {% if section.settings.main_image != blank %}
          {{ section.settings.main_image | image_url: width: 800 | image_tag: class: 'story-main-img', loading: 'lazy' }}
        {% else %}
           {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}

        {% if section.settings.sticker_image != blank %}
          <div class="story-sticker">
            {{ section.settings.sticker_image | image_url: width: 120 | image_tag: loading: 'lazy' }}
          </div>
        {% endif %}
      </div>

      {% if section.settings.image_caption != blank %}
        <p class="story-caption">{{ section.settings.image_caption }}</p>
      {% endif %}
    </div>

  </div>
</section>

<style>
  /* Scoped Variables */
  .story-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 10px 20px;
    font-family: {{ section.settings.font_family }}; 
  }

  .story-container {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center; /* Align vertically center */
    justify-content: space-between;
    gap: 60px;
    padding-top: 30px;
  }

  /* --- LEFT COLUMN --- */
  .story-text-col {
    flex: 1;
    color: {{ section.settings.text_color }};
  }

  .story-body {
    font-size: 20px;
    line-height: 1.4;
    margin-bottom: 24px;
  }

  /* Highlight styling for specific words (bold/purple) */
  .story-body strong {
    color: {{ section.settings.highlight_color }};
    font-weight: 800;
  }

  .story-list-wrapper p{
    font-size: 20px;
    line-height: 0.4;
  }
  .story-list-wrapper ul {
    list-style: none; /* Remove default bullets */
    padding-left: 10px;
    margin: 0;
  }

  .story-list-wrapper li {
    font-size: 20px;
    line-height: 1.4;
    position: relative;
    padding-left: 20px;
    color: {{ section.settings.text_color }};
  }

  /* Custom Bullet Dot */
  .story-list-wrapper li::before {
    content: "•";
    color: {{ section.settings.highlight_color }};
    font-weight: bold;
    position: absolute;
    left: 0;
  }

  /* --- RIGHT COLUMN --- */
  .story-image-col {
    flex: 0 0 45%; /* Image takes roughly 45% width */
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .story-image-wrapper {
    position: relative;
    display: inline-block;
  }

  .story-main-img {
    width: 80%;
    margin-top:-80px;
    height: auto;
    border-radius: 4px; /* Slight rounding if needed */
    display: block;
    /*transform: rotate(2deg);  Slight tilt matching reference */
    box-shadow: 4px 4px 0px rgba(0,0,0,0.1); /* Subtle shadow */
  }

  /* Sticker Positioning */
  .story-sticker {
    position: absolute;
    top: -118px;
    right: 64px;
    width: 80px;
    height: auto;
    z-index: 2;
    transform: rotate(15deg);
  }

  .story-caption {
    margin-top: 15px;
    font-family: Aesthet-Nova-Light !important; /* Handwriting style fallback */
    font-weight: 700;
    color: {{ section.settings.highlight_color }};
    font-size: 16px;
    margin-right: 85px;
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 900px) {
    .story-container {
      flex-direction: column-reverse; /* Image on top on mobile? Or keep bottom? */
      gap: 40px;
    }
    
    .story-image-col {
      width: 100%;
      flex: auto;
    }
    
    .story-sticker {
      width: 60px;
      top: -20px;
      right: -10px;
    }
  }
  /* =====================================
   MOBILE FIX — STORY SECTION
   ===================================== */
@media (max-width: 768px) {

  /* Section padding safety */
  .story-section-{{ section.id }} {
    padding: 20px 12px;
  }

  /* Stack layout cleanly */
  .story-container {
    flex-direction: column;
    gap: 10px;
    padding-top: 0;
  }

  /* ---------- IMAGE COLUMN ---------- */
  .story-image-col {
    width: 100%;
    align-items: center;
  }

  .story-image-wrapper {
    width: 100%;
    text-align: center;
    display: flex;
    justify-content: space-evenly;
  }

  .story-main-img {
    width: 90%;
    margin-top: 0; /* remove negative margin */
    box-shadow: 2px 2px 0 rgba(0,0,0,0.08);
  }

  /* Sticker: keep it but constrain it */
  .story-sticker {
    width: 48px;
    top: -10px;
    right: 10px;
    transform: rotate(10deg);
  }

  /* Caption centered */
  .story-caption {
    margin-right: 0;
    margin-top: 10px;
    font-size: 13px;
    text-align: center;
  }

  /* ---------- TEXT COLUMN ---------- */
  .story-text-col {
    width: 100%;
    text-align: center;
  }

  .story-body {
    font-size: 14px;
    line-height: 1.3;
    margin-bottom: 16px;
  }

  /* Bullet list cleanup */
  .story-list-wrapper {
    width: 100%;
    text-align: left;
  }

  .story-list-wrapper ul {
    padding-left: 0;
  }

  .story-list-wrapper li {
    font-size: 14px;
    line-height: 1.3;
    padding-left: 16px;
  }

  .story-list-wrapper li::before {
    left: 0;
  }
  .story-list-wrapper p {
    font-size: 16px;
  }
}

</style>

{% schema %}
{
  "name": "Story with Image",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FBF3CC"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#6A6AF0"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight/Bold Color",
      "default": "#5A56B3"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "main_text",
      "label": "Main Paragraphs",
      "default": "<p>Years later, that same instinct pulled us back into the field in 2025...</p>"
    },
    {
      "type": "richtext",
      "id": "bullet_list",
      "label": "Bulleted List (Bottom)",
      "default": "<ul><li>farmers were growing high-quality produce</li><li>trader mismanagement was letting contamination enter</li></ul>"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Photo"
    },
    {
      "type": "image_picker",
      "id": "sticker_image",
      "label": "Sun/Star Sticker Icon"
    },
    {
      "type": "text",
      "id": "image_caption",
      "label": "Caption",
      "default": "(somewhere in the Western Ghats)"
    }
  ],
  "presets": [
    {
      "name": "Story with Image"
    }
  ]
}
{% endschema %}