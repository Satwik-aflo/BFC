{% comment %}
  Icon Grid Section
  2x2 icon + text layout
{% endcomment %}

<section class="icon-grid-section icon-grid-section-{{ section.id }}">
  <div class="icon-grid-container">

    {% for block in section.blocks %}
      <div class="grid-item" {{ block.shopify_attributes }}>
        <div class="icon-box">

          {% if block.settings.icon_svg != blank %}
            {{ block.settings.icon_svg }}
          {% elsif block.settings.icon_image != blank %}
            {{ block.settings.icon_image | image_url: width: 40 | image_tag }}
          {% endif %}

        </div>

        <span class="grid-text">
          {{ block.settings.text }}
        </span>
      </div>
    {% endfor %}

  </div>
</section>

<style>
.icon-grid-section-{{ section.id }} {
  background-color: {{ section.settings.bg_color }};
  padding: 20px 0;
}

.icon-grid-section-{{ section.id }} .icon-grid-container {
  max-width: 600px;
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px 10px;
}

.icon-grid-section-{{ section.id }} .grid-item {
  display: flex;
  align-items: center;
}

.icon-grid-section-{{ section.id }} .icon-box {
  width: 30px;
  min-width: 30px;
  margin-right: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-grid-section-{{ section.id }} .icon-box svg,
.icon-grid-section-{{ section.id }} .icon-box img {
  width: 100%;
  height: auto;
  display: block;
}

.icon-grid-section-{{ section.id }} .grid-text {
  font-size: 14px;
  color: #1a1a1a;
  line-height: 1.2;
  font-weight: 500;
}

/* Mobile */
@media (max-width: 480px) {
  .icon-grid-section-{{ section.id }} .icon-grid-container {
    grid-template-columns: 1fr;
  }
}
</style>

{% schema %}
{
  "name": "Icon Grid",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFFBE6"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Icon item",
      "settings": [
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "SVG icon (paste SVG code)"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image (optional)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Feature text"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Icon Grid",
      "category": "Custom",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
