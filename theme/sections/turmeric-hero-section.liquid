<style> 
    :root {
    --color-primary: #f59e0b;
    --color-secondary: #fef3c7;
    --color-dark: #78350f;
    --color-text: #451a03;
    --color-white: #ffffff;
    --spacing-sm: 1rem;
    --spacing-md: 1.75rem;
    --spacing-lg: 2.5rem;
    --border-radius: 50%;
}

/* reset inside hero */
.hero-section * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

.hero-section {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    line-height: 1.6;
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    /* no full-screen height */
    display: flex;
    align-items: center;
    padding: 1.75rem var(--spacing-md); /* reduced vertical padding */
    padding-top: calc(1.75rem + var(--header-height, 45px));
    position: relative;
}

.hero-section .container {
    max-width: 1200px; /* reduced from 1400px */
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr; /* slightly favor text column */
    gap: 2rem; /* reduced gap */
    align-items: center;
}

.hero-content {
    padding-right: 1.25rem;
}

.hero-title {
    font-size: clamp(2.1rem, 3.9vw, 3.5rem); /* slightly smaller */
    color: var(--color-dark);
    line-height: 1.1;
    margin-bottom: 1.4rem;
    font-weight: 800;
}

.hero-title .highlight {
    display: flex;
    align-items: center;
    gap: 0.8rem;
}

.turmeric-icon {
    width: 70px;
    height: 70px;
    background-color: var(--color-primary);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 2.1rem;
    box-shadow: 0 3px 16px rgba(245, 158, 11, 0.3);
}

.hero-description {
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 1.6rem; /* reduced */
    line-height: 1.7;
    max-width: 540px;
    opacity: 0.9;
}

.cta-buttons {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
}

.btn {
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.1);
}

.btn-primary {
    background-color: var(--color-primary);
    color: var(--color-dark);
}

.btn-primary:hover {
    background-color: #d97706;
    transform: translateY(-2px);
    box-shadow: 0 5px 16px rgba(245, 158, 11, 0.4);
}

.btn-secondary {
    background-color: var(--color-white);
    color: var(--color-dark);
    border: 2px solid transparent;
}

.btn-secondary:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
}

.btn-icon {
    font-size: 1.1rem;
}

/* IMAGE SIDE */
.hero-images {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: repeat(2, 1fr);
    gap: 1.1rem;        /* reduced */
    padding: 1.25rem;   /* reduced */
}

.image-circle {
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    border: 4px solid var(--color-white);
    position: relative;
    background-color: var(--color-white);
    transition: transform 0.3s ease;
}

.image-circle:hover {
    transform: scale(1.04);
}

.image-circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.circle-1 {
    grid-column: 1;
    grid-row: 1 / 3;
    aspect-ratio: 1;
}

.circle-2 {
    grid-column: 2;
    grid-row: 1;
    aspect-ratio: 1;
}

.circle-3 {
    grid-column: 2;
    grid-row: 2 / 4;
    aspect-ratio: 1;
}

/* CENTER BADGE */
.center-badge {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 130px;   /* reduced */
    height: 130px;  /* reduced */
    background-color: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    box-shadow: 0 9px 30px rgba(245, 158, 11, 0.4);
    border: 7px solid var(--color-white);
    z-index: 2;
    cursor: pointer;
    transition: transform 0.3s ease;
}

.center-badge:hover {
    transform: translate(-50%, -50%) scale(1.07);
}

.play-icon {
    width: 52px;   /* reduced */
    height: 52px;
    background-color: var(--color-dark);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.45rem;
}

.play-icon::after {
    content: '';
    width: 0;
    height: 0;
    border-left: 16px solid var(--color-white);
    border-top: 11px solid transparent;
    border-bottom: 11px solid transparent;
    margin-left: 4px;
}

.badge-text {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-dark);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1.2;
}

/* PLACEHOLDER */
.placeholder-image {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
}

.placeholder-image img {
    height: 100%;
    width: 100%;
    object-fit: contain;
}

/* tablet */
@media (max-width: 968px) {

    .hero-section {
        padding: 1.5rem var(--spacing-md);
        padding-top: calc(1.5rem + var(--header-height, 45px));
    }

    .hero-section .container {
        grid-template-columns: 1fr;
        gap: var(--spacing-md);
    }

    .hero-content {
        padding-right: 0;
        text-align: center;
    }

    .hero-title {
        font-size: 2.1rem;
    }

    .hero-description {
        margin-left: auto;
        margin-right: auto;
    }

    .cta-buttons {
        justify-content: center;
    }

    .hero-images {
        max-width: 460px;
        margin: 0 auto;
    }
}

/* mobile */
@media (max-width: 640px) {
    .hero-section {
        padding: 1.25rem;
        padding-top: 3.5rem; /* reduced a bit more */
    }

    .hero-title {
        font-size: 1.9rem;
    }

    .turmeric-icon {
        width: 56px;
        height: 56px;
        font-size: 1.8rem;
    }

    .btn {
        padding: 0.8rem 1.6rem;
        font-size: 0.9rem;
    }

    .center-badge {
        width: 115px;
        height: 115px;
        border-width: 6px;
    }

    .hero-images {
        gap: 0.85rem;
        padding: 0.9rem;
    }
}


    </style>

<section class="hero-section" data-hero-id="{{ section.id }}"> 
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">
        {{ section.settings.hero_title }}
      </h1>
      
      <p class="hero-description">
        {{ section.settings.hero_description }}
      </p>
      
      <div class="cta-buttons">
        {% if section.settings.primary_button_text != blank %}
          <a href="{{ section.settings.primary_button_link }}" class="btn btn-primary">
            {{ section.settings.primary_button_text }}
            {% if section.settings.primary_button_icon != blank %}
              <span class="btn-icon">{{ section.settings.primary_button_icon }}</span>
            {% endif %}
          </a>
        {% endif %}

        {% if section.settings.secondary_button_text != blank %}
          <a href="{{ section.settings.secondary_button_link }}" class="btn btn-secondary">
            {% if section.settings.secondary_button_icon != blank %}
              <span class="btn-icon">{{ section.settings.secondary_button_icon }}</span>
            {% endif %}
            {{ section.settings.secondary_button_text }}
          </a>
        {% endif %}
      </div>
    </div>
    
    <div class="hero-images">
      <div class="image-circle circle-1">
        <div class="placeholder-image">
          {% if section.settings.image_1 != blank %}
            <img 
              src="{{ section.settings.image_1 | img_url: '800x800' }}" 
              alt="{{ section.settings.image_1_alt | escape }}"
            >
          {% else %}
            <span>Image 1</span>
          {% endif %}
        </div>
      </div>

      <div class="image-circle circle-2">
        <div class="placeholder-image">
          {% if section.settings.image_2 != blank %}
            <img 
              src="{{ section.settings.image_2 | img_url: '800x800' }}" 
              alt="{{ section.settings.image_2_alt | escape }}"
            >
          {% else %}
            <span>Image 2</span>
          {% endif %}
        </div>
      </div>

      <div class="image-circle circle-3">
        <div class="placeholder-image">
          {% if section.settings.image_3 != blank %}
            <img 
              src="{{ section.settings.image_3 | img_url: '800x800' }}" 
              alt="{{ section.settings.image_3_alt | escape }}"
            >
          {% else %}
            <span>Image 3</span>
          {% endif %}
        </div>
      </div>
      
      <div class="center-badge" data-hero-badge>
        <div class="play-icon"></div>
        <div class="badge-text">
          {{ section.settings.badge_text | newline_to_br }}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    var hero = document.querySelector('[data-hero-id="{{ section.id }}"]');
    if (!hero) return;

    // Smooth scroll for anchors inside this hero only
    hero.querySelectorAll('a[href^="#"]').forEach(function(anchor) {
      anchor.addEventListener('click', function(e) {
        var href = this.getAttribute('href');
        if (!href || href === '#') return;
        var target = document.querySelector(href);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      });
    });

    // Center badge click -> open link if set
    var centerBadge = hero.querySelector('[data-hero-badge]');
    if (centerBadge) {
      var badgeLink = "{{ section.settings.badge_link | escape }}";
      centerBadge.addEventListener('click', function() {
        if (badgeLink && badgeLink !== '') {
          window.location.href = badgeLink;
        }
      });
    }

    // Simple stagger delay on circles
    var imageCircles = hero.querySelectorAll('.image-circle');
    imageCircles.forEach(function(circle, index) {
      circle.style.transitionDelay = (index * 0.1) + 's';
    });
  })();
</script>

{% schema %}
{
  "name": "Turmeric hero",
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "Ensuring A Happy, Healthy Life With Golden Turmeric!"
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Hero description",
      "default": "We provide premium, 100% organic turmeric sourced directly from sustainable farms, ensuring the highest quality, purity, and health benefits for you and your family with natural goodness and care."
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "primary_button_icon",
      "label": "Primary button icon (optional)",
      "default": "→"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary button text",
      "default": "Watch Video"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_icon",
      "label": "Secondary button icon (optional)",
      "default": "▶"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Circle image 1"
    },
    {
      "type": "text",
      "id": "image_1_alt",
      "label": "Circle image 1 alt text",
      "default": "Turmeric image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Circle image 2"
    },
    {
      "type": "text",
      "id": "image_2_alt",
      "label": "Circle image 2 alt text",
      "default": "Turmeric image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Circle image 3"
    },
    {
      "type": "text",
      "id": "image_3_alt",
      "label": "Circle image 3 alt text",
      "default": "Turmeric image 3"
    },
    {
      "type": "textarea",
      "id": "badge_text",
      "label": "Center badge text",
      "default": "Organic\n• Turmeric •\nFarm Fresh\n• Quality •"
    },
    {
      "type": "url",
      "id": "badge_link",
      "label": "Center badge click link",
      "info": "Optional. If set, clicking the badge will open this link."
    }
  ],
  "presets": [
    {
      "name": "Turmeric hero"
    }
  ]
}
{% endschema %}
