<style>
        .turmeric-quality-section {
            --color-primary: #d97706;
            --color-primary-dark: #b45309;
            --color-text-dark: #78350f;
            --color-text-medium: #92400e;
            --color-bg-cream: #fef3c7;
            --color-bg-light: #fffbeb;
            --color-white: #ffffff;
            --color-border: #fde68a;
            --spacing-sm: 1rem;
            --spacing-md: 2rem;
            --spacing-lg: 3rem;
            --spacing-xl: 4rem;
        }

        .turmeric-quality-section * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        .turmeric-quality-section {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            line-height: 1.6;
            background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
            padding: var(--spacing-xl) var(--spacing-md);
            position: relative;
            overflow: hidden;
        }

        .quality-container {
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: var(--spacing-xl);
        }

        .quality-content {
            padding: var(--spacing-md);
            flex: 1;
        }

        .quality-title {
            font-size: clamp(2rem, 4vw, 3.5rem);
            font-weight: 800;
            color: var(--color-text-dark);
            line-height: 1.1;
            margin-bottom: 1rem;
            text-transform: uppercase;
            letter-spacing: -1px;
        }

        .quality-subtitle {
            font-size: clamp(1.2rem, 2vw, 1.5rem);
            color: var(--color-text-medium);
            margin-bottom: var(--spacing-md);
            font-weight: 400;
        }

        .quality-description {
            font-size: 1.05rem;
            color: var(--color-text-medium);
            line-height: 1.7;
            margin-bottom: var(--spacing-md);
        }

        .cta-button {
            display: inline-block;
            padding: 0.875rem 2rem;
            background-color: transparent;
            color: var(--color-text-dark);
            border: 2px solid var(--color-text-dark);
            border-radius: 4px;
            font-size: 0.95rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            cursor: pointer;
            margin-top: 1rem;
        }

        .cta-button:hover {
            background-color: var(--color-text-dark);
            color: var(--color-bg-cream);
            transform: translateX(5px);
        }

        .cta-button::after {
            content: ' ›';
            margin-left: 0.5rem;
            font-size: 1.2rem;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: var(--spacing-md);
            flex-shrink: 0;
            width: 400px;
        }

        .feature-item {
            text-align: center;
            padding: var(--spacing-md);
        }

        .feature-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto var(--spacing-sm);
            border-radius: 50%;
            border: 3px solid var(--color-text-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            background: var(--color-white);
        }

        .feature-text {
            font-size: 0.95rem;
            color: var(--color-text-medium);
            font-weight: 500;
        }

        .quality-image-container {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: var(--spacing-md);
        }

        .image-wrapper {
            position: relative;
            width: 100%;
            max-width: 600px;
        }

        .quality-image {
            width: 100%;
            height: auto;
            border-radius: 12px;
            box-shadow: 0 25px 60px rgba(120, 53, 15, 0.2);
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
            aspect-ratio: 16/11;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 5rem;
        }

        .quality-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 12px;
        }

        /* Decorative wave element */
        .turmeric-quality-section::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 50%;
            height: 100%;
            background: linear-gradient(135deg, transparent 0%, rgba(253, 230, 138, 0.3) 100%);
            clip-path: ellipse(80% 100% at 100% 50%);
            z-index: 0;
            pointer-events: none;
        }

        .quality-container {
            position: relative;
            z-index: 1;
        }

        @media (max-width: 968px) {
            .quality-container {
                flex-direction: column;
                gap: var(--spacing-md);
            }

            .quality-content {
                text-align: center;
            }

            .features-grid {
                width: 100%;
                max-width: 500px;
                margin: var(--spacing-lg) auto 0;
            }
        }

        @media (max-width: 640px) {
            .turmeric-quality-section {
                padding: var(--spacing-lg) var(--spacing-sm);
            }

            .quality-title {
                font-size: 2rem;
            }

            .quality-subtitle {
                font-size: 1.1rem;
            }

            .features-grid {
                grid-template-columns: 1fr 1fr;
                gap: var(--spacing-sm);
            }

            .feature-icon {
                width: 60px;
                height: 60px;
                font-size: 1.5rem;
            }

            .feature-text {
                font-size: 0.85rem;
            }

            .quality-image {
                font-size: 3rem;
            }
        }
    </style>

<section class="turmeric-quality-section"> 
    <div class="quality-container">
        <div class="quality-content">
            <h2 class="quality-title">
              {{ section.settings.title }}
            </h2>
            <p class="quality-subtitle">
              {{ section.settings.subtitle }}
            </p>
            
            <p class="quality-description">
              {{ section.settings.description }}
            </p>
            
            {% if section.settings.button_text != blank %}
              <a href="{{ section.settings.button_link }}" class="cta-button">
                  {{ section.settings.button_text }}
              </a>
            {% endif %}
        </div>

        <div class="features-grid">
          {% for block in section.blocks %}
            <div class="feature-item" {{ block.shopify_attributes }}>
                <div class="feature-icon">
                    {{ block.settings.icon }}
                </div>
                <p class="feature-text">
                    {{ block.settings.text }}
                </p>
            </div>
          {% endfor %}
        </div>
    </div>
</section>

<script>
        // Smooth scroll functionality
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Intersection Observer for animation
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -100px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, observerOptions);

        // Add animation to elements
        const animatedElements = document.querySelectorAll('.quality-content, .quality-image-container, .feature-item');
        animatedElements.forEach((el, index) => {
            el.style.opacity = '0';
            el.style.transform = 'translateY(30px)';
            el.style.transition = `opacity 0.6s ease ${index * 0.1}s, transform 0.6s ease ${index * 0.1}s`;
            observer.observe(el);
        });
</script>

{% schema %}
{
  "name": "Turmeric quality section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Pure, Organic and Chemical-Free Turmeric"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "It's nature, only nature."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Our turmeric is grown in pristine farms and not in chemical laboratories. When you bring home Golden Harvest, you bring turmeric that's healthy, wholesome and completely chemical-free, preserving nature's original golden potency."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or text)",
          "default": "🌱"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Feature text",
          "default": "100% Organic ingredients"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Turmeric quality section",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "🌱",
            "text": "100% Organic ingredients"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "💧",
            "text": "Natural spring water"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "🌾",
            "text": "Traditional farming methods"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "🚫",
            "text": "No chemical additives"
          }
        }
      ]
    }
  ]
}
{% endschema %}
