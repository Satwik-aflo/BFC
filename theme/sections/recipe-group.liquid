{%- liquid
  assign group_heading = section.settings.heading
  assign group_intro = section.settings.intro
-%}

<section
  class="recipe-group color-{{ section.settings.color_scheme }} recipe-group--{{ section.id }}"
  style="--rg-pad-top: {{ section.settings.padding_top }}px; --rg-pad-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="recipe-group__inner">
    {%- if group_heading != blank or group_intro != blank -%}
      <header class="recipe-group__head">
        {%- if group_heading != blank -%}
          <h2 class="recipe-group__title">{{ group_heading | escape }}</h2>
        {%- endif -%}
        {%- if group_intro != blank -%}
          <p class="recipe-group__intro">{{ group_intro }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="recipe-grid">
        {%- for block in section.blocks -%}
          <article class="recipe-card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <figure class="recipe-card__media">
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 750px) 50vw, 100vw',
                    widths: '300, 400, 600, 800',
                    alt: block.settings.image.alt | default: block.settings.title
                }}
              </figure>
            {%- endif -%}

            {%- if block.settings.badge != blank -%}
              <span class="recipe-card__badge">{{ block.settings.badge | escape }}</span>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="recipe-card__title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}

            {%- if block.settings.ingredients != blank -%}
              <div class="recipe-card__block">
                <h4 class="recipe-card__label">Ingredients</h4>
                <div class="recipe-card__rte">{{ block.settings.ingredients }}</div>
              </div>
            {%- endif -%}

            {%- if block.settings.method != blank -%}
              <div class="recipe-card__block">
                <h4 class="recipe-card__label">Method</h4>
                <div class="recipe-card__rte">{{ block.settings.method }}</div>
              </div>
            {%- endif -%}

            {%- if block.settings.hack != blank -%}
              <div class="recipe-card__hack">{{ block.settings.hack }}</div>
            {%- endif -%}

            {%- if block.settings.pdf != blank -%}
              <p class="recipe-card__pdf">
                <a class="recipe-card__pdf-link" href="{{ block.settings.pdf }}" target="_blank" rel="noopener">
                  <span class="recipe-card__hand" aria-hidden="true">&#9758;</span> Download recipe (PDF)
                </a>
              </p>
            {%- endif -%}

            {%- if block.settings.signoff != blank -%}
              <p class="recipe-card__signoff">{{ block.settings.signoff | escape }}</p>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .recipe-group {
    padding-block: var(--rg-pad-top, 56px) var(--rg-pad-bottom, 56px);
    padding-inline: 5vw;
  }

  .recipe-group__inner {
    max-width: 72rem;
    margin-inline: auto;
  }

  .recipe-group__head {
    max-width: 50rem;
    margin-inline: auto;
    margin-block-end: 2.5rem;
    text-align: center;
  }

  .recipe-group__title {
    font-family: var(--font-heading--family);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.1;
    margin: 0;
    overflow-wrap: break-word;
    hyphens: auto;
  }

  .recipe-group__intro {
    font-family: var(--font-body--family);
    font-size: 1rem;
    line-height: 1.6;
    margin-block-start: 1rem;
    opacity: 0.9;
  }

  .recipe-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .recipe-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .recipe-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    border: 1px solid currentColor;
    background: var(--color-background, #fbf3cc);
    color: var(--color-foreground, #000000);
  }

  .recipe-card__media {
    margin: -1.25rem -1.25rem 0.25rem;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-block-end: 1px solid currentColor;
  }

  .recipe-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .recipe-card__badge {
    align-self: flex-start;
    font-family: var(--font-heading--family);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8125rem;
    background: #f84b21;
    color: #fbf3cc;
    padding: 0.3rem 0.7rem;
  }

  .recipe-card__title {
    font-family: var(--font-heading--family);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 1.25rem;
    line-height: 1.15;
    margin: 0;
    color: #244f24;
    overflow-wrap: break-word;
    hyphens: auto;
  }

  .recipe-card__block {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .recipe-card__label {
    font-family: var(--font-heading--family);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.875rem;
    margin: 0;
    color: #c2390f;
  }

  .recipe-card__rte {
    font-family: var(--font-body--family);
    font-size: 1rem;
    line-height: 1.55;
  }

  .recipe-card__rte ul,
  .recipe-card__rte ol {
    margin: 0;
    padding-inline-start: 1.1rem;
  }

  .recipe-card__rte li {
    margin-block: 0.2rem;
  }

  .recipe-card__rte p {
    margin: 0;
  }

  .recipe-card__hack {
    font-family: var(--font-body--family);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.55;
    color: #5d57c5;
  }

  .recipe-card__hack p {
    margin: 0;
  }

  .recipe-card__pdf {
    margin: 0.25rem 0 0;
  }

  .recipe-card__pdf-link {
    font-family: var(--font-heading--family);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.9375rem;
    color: inherit;
  }

  .recipe-card__hand {
    font-style: normal;
  }

  .recipe-card__signoff {
    font-family: var(--font-body--family);
    font-size: 1rem;
    line-height: 1.55;
    margin: 0;
    opacity: 0.85;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Recipe group",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Group heading",
      "default": "Ingredient"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Group intro",
      "default": "A short description of this ingredient and how to use it."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "recipe",
      "name": "Recipe",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge"
        },
        {
          "type": "richtext",
          "id": "ingredients",
          "label": "Ingredients"
        },
        {
          "type": "richtext",
          "id": "method",
          "label": "Method"
        },
        {
          "type": "richtext",
          "id": "hack",
          "label": "Boring Hack callout"
        },
        {
          "type": "url",
          "id": "pdf",
          "label": "PDF download (optional)"
        },
        {
          "type": "text",
          "id": "signoff",
          "label": "Sign-off (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Recipe group",
      "blocks": [
        { "type": "recipe" },
        { "type": "recipe" }
      ]
    }
  ]
}
{% endschema %}
