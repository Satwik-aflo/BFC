{% comment %}
  Section: How We Are Different – comparison table with center SVG card
  Save as: sections/how-we-are-different.liquid
{% endcomment %}

<section class="hwd-section">
  <div class="hwd-section__inner page-width">

    <h2 class="hwd-section__heading">
      {{ section.settings.heading }}
    </h2>

    {%- comment -%} Top border SVG {%- endcomment -%}
    {% if section.settings.top_border_svg != blank %}
      <div class="hwd-border hwd-border--top">
        {{ section.settings.top_border_svg }}
      </div>
    {% endif %}

    <div class="hwd-grid">

      {%- comment -%} Left questions column {%- endcomment -%}
      <div class="hwd-col hwd-col--left">
        {% for row in section.blocks %}
          <div class="hwd-row">
            <div class="hwd-cell hwd-cell--question">
              {{ row.settings.question }}
            </div>
          </div>
        {% endfor %}
      </div>

      {%- comment -%} Middle SVG card + our answers {%- endcomment -%}
      <div class="hwd-col hwd-col--middle">

        {% if section.settings.card_svg != blank %}
          <div class="hwd-card-svg">
            {{ section.settings.card_svg }}
          </div>
        {% endif %}

        <div class="hwd-card-rows">
          {% for row in section.blocks %}
            <div class="hwd-row">
              <div class="hwd-cell hwd-cell--our">
                {{ row.settings.our_text }}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      {%- comment -%} Right 2 columns: standard & mass market {%- endcomment -%}
      <div class="hwd-col hwd-col--right">
        {% for row in section.blocks %}
          <div class="hwd-row">
            <div class="hwd-cell hwd-cell--standard">
              {{ row.settings.standard_text }}
            </div>
            <div class="hwd-cell hwd-cell--mass">
              {{ row.settings.mass_text }}
            </div>
          </div>
        {% endfor %}
      </div>

    </div>

    {%- comment -%} Bottom border SVG {%- endcomment -%}
    {% if section.settings.bottom_border_svg != blank %}
      <div class="hwd-border hwd-border--bottom">
        {{ section.settings.bottom_border_svg }}
      </div>
    {% endif %}

  </div>

  <style>
    .hwd-section {
      background: #ffeeb8;
      padding: 40px 0 60px;
    }

    .hwd-section__heading {
      text-align: center;
      color: #f2583a;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin: 0 0 24px;
      font-weight: 700;
      font-size: 26px;
    }

    .hwd-border {
      text-align: center;
      margin: 12px 0;
    }

    .hwd-border svg {
      max-width: 100%;
      height: auto;
      display: inline-block;
    }

    .hwd-grid {
      display: grid;
      grid-template-columns: minmax(150px, 1.1fr) minmax(220px, 1.3fr) minmax(260px, 1.6fr);
      gap: 0;
      align-items: stretch;
      margin-top: 16px;
      position: relative;
    }

    .hwd-col {
      position: relative;
    }

    .hwd-row {
      display: grid;
      grid-template-columns: 1fr;
      border-bottom: 2px solid #c5a4d4;
    }

    .hwd-col--right .hwd-row {
      grid-template-columns: 1fr 1fr;
      border-left: 2px solid #c5a4d4;
    }

    .hwd-cell {
      padding: 16px 18px;
      font-size: 14px;
      line-height: 1.5;
    }

    .hwd-cell--question {
      font-weight: 700;
      color: #404aa5;
      text-transform: uppercase;
    }

    .hwd-cell--our {
      font-weight: 500;
      color: #000;
    }

    .hwd-cell--standard,
    .hwd-cell--mass {
      font-size: 14px;
      color: #d65b3b;
    }

    .hwd-col--middle {
      position: relative;
      border-left: 2px solid #c5a4d4;
      border-right: 2px solid #c5a4d4;
    }

    .hwd-card-svg {
      position: absolute;
      top: -40px; /* adjust based on your SVG */
      left: 50%;
      transform: translateX(-50%);
      z-index: 1;
      pointer-events: none;
    }

    .hwd-card-svg svg {
      max-width: 260px;
      height: auto;
    }

    .hwd-card-rows {
      position: relative;
      z-index: 2;
    }

    @media (max-width: 900px) {
      .hwd-grid {
        grid-template-columns: 1fr;
      }

      .hwd-col--middle,
      .hwd-col--right {
        border-left: none;
        border-right: none;
      }

      .hwd-col--right .hwd-row {
        grid-template-columns: 1fr;
      }

      .hwd-card-svg {
        position: static;
        transform: none;
        text-align: center;
        margin-bottom: 12px;
      }
    }
  </style>
</section>

{% schema %}
{
  "name": "How we are different",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "HOW WE ARE DIFFERENT"
    },
    {
      "type": "textarea",
      "id": "top_border_svg",
      "label": "Top border SVG",
      "info": "Paste raw SVG markup."
    },
    {
      "type": "textarea",
      "id": "bottom_border_svg",
      "label": "Bottom border SVG",
      "info": "Paste raw SVG markup."
    },
    {
      "type": "textarea",
      "id": "card_svg",
      "label": "Center card SVG",
      "info": "Paste SVG for yellow rounded card with logo."
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question (left)"
        },
        {
          "type": "text",
          "id": "our_text",
          "label": "Our column text"
        },
        {
          "type": "text",
          "id": "standard_text",
          "label": "Standard 'healthy' brands text"
        },
        {
          "type": "text",
          "id": "mass_text",
          "label": "Mass market brands text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How we are different",
      "category": "Custom sections"
    }
  ]
}
{% endschema %}
