{% comment %}
  Boring Foods homepage hero. Full-bleed photo + scrim, logo, tagline (with the
  Musloner "boring," script accent) and two CTAs. Ports the static-site load-in:
  Ken Burns photo zoom, fade-up logo/CTA, and a line-by-line masked tagline
  reveal. Brand tokens (--kulfi-malai, --text-xl, --space-*, --gutter,
  --ease-out) and the .bfc-btn / .bfc-script classes come from brand.liquid.

  Replaces the old inline custom-liquid hero so the CSS/JS/Liquid can be
  validated and edited normally, and the photo/logo/CTAs are theme-editable.
{% endcomment %}

<section class="bfc-hero" id="top">
  <div class="bfc-hero__media" aria-hidden="true">
    {%- if section.settings.image -%}
      {{ section.settings.image | image_url: width: 3000 | image_tag:
         class: 'bfc-hero__photo', alt: '', loading: 'eager', preload: true,
         widths: '600, 900, 1200, 1600, 2000, 2400, 3000', sizes: '100vw' }}
    {%- else -%}
      <img class="bfc-hero__photo" src="{{ 'hero-powder.webp' | asset_url }}"
           alt="" loading="eager" fetchpriority="high" width="1280" height="750">
    {%- endif -%}
    <div class="bfc-hero__scrim"></div>
  </div>

  {%- if section.settings.badge_left != blank -%}
    <aside class="bfc-hero__meta bfc-hero__meta--left">{{ section.settings.badge_left | escape }}</aside>
  {%- endif -%}
  {%- if section.settings.badge_right != blank -%}
    <aside class="bfc-hero__meta bfc-hero__meta--right">{{ section.settings.badge_right | escape }}</aside>
  {%- endif -%}

  {%- if section.settings.logo -%}
    <img class="bfc-hero__logo" src="{{ section.settings.logo | image_url: width: 680 }}"
         alt="{{ shop.name | escape }}" width="340" height="190">
  {%- else -%}
    <img class="bfc-hero__logo" src="{{ 'logo-web4.webp' | asset_url }}"
         alt="{{ shop.name | escape }}" width="340" height="190">
  {%- endif -%}

  <p class="bfc-hero__tag split-lines">In a world of synthetic, flashy health fads, we bring you back to the basics &mdash; <span class="bfc-script">boring,</span> powerful, time-tested foods.</p>

  <div class="bfc-hero__cta">
    <a class="bfc-btn" href="{{ section.settings.cta1_link | default: routes.all_products_collection_url }}">
      <span class="hand">&#9758;</span> {{ section.settings.cta1_label | escape }}
    </a>
    <a class="bfc-btn bfc-btn--light" href="{{ section.settings.cta2_link | default: '#manifesto' }}">
      <span class="hand">&#9758;</span> {{ section.settings.cta2_label | escape }}
    </a>
  </div>
</section>

{% stylesheet %}
  .bfc-hero { min-height: 100svh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; position: relative; padding: 7rem var(--gutter) 8rem; color: var(--kulfi-malai); overflow: hidden; }
  .bfc-hero__media { position: absolute; inset: 0; z-index: 0; overflow: hidden; }
  .bfc-hero__photo { width: 100%; height: 100%; object-fit: cover; transform: scale(1.12); animation: bfc-kenburns 14s var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) forwards; }
  .bfc-hero__scrim { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.42) 35%, rgba(0, 0, 0, 0.4) 60%, rgba(0, 0, 0, 0.62) 100%); }
  .bfc-hero > :not(.bfc-hero__media, .bfc-hero__meta) { position: relative; z-index: 1; }
  .bfc-hero__meta { position: absolute; top: 50%; transform: translateY(-50%); z-index: 1; width: min-content; font-family: var(--font-heading--family); font-size: var(--text-xs, 0.75rem); font-weight: 700; letter-spacing: 0.18em; line-height: 1.7; text-transform: uppercase; color: var(--kohl-black); background: var(--mango-yellow); border: 2px solid var(--kohl-black); outline: 1px solid var(--kohl-black); outline-offset: 3px; padding: 0.8em 1.2em; opacity: 0; animation: bfc-rise 1s var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 0.9s both; }
  .bfc-hero__meta--left { left: var(--gutter); text-align: left; }
  .bfc-hero__meta--right { right: var(--gutter); text-align: right; }
  @media (max-width: 749px) { .bfc-hero__meta { display: none; } }
  .bfc-hero__logo { width: clamp(200px, 26vw, 340px); height: auto; margin-bottom: var(--space-4); opacity: 0; animation: bfc-rise 1s var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 0.15s both; }
  .bfc-hero__tag { margin-top: var(--space-2); font-size: var(--text-xl); font-weight: 500; line-height: 1.45; max-width: 44rem; text-shadow: 0 1px 3px rgba(0, 0, 0, 0.55), 0 4px 22px rgba(0, 0, 0, 0.5); }
  .bfc-hero__tag .bfc-script { font-size: 1.25em; }
  .bfc-hero__tag .line { display: block; overflow: hidden; }
  .bfc-hero__tag .line-inner { display: block; transform: translateY(110%); transition: transform 1.1s var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)); transition-delay: calc(var(--line-i, 0) * 0.09s); }
  .bfc-hero__tag.is-visible .line-inner { transform: translateY(0); }
  .bfc-hero__cta { margin-top: var(--space-4); display: flex; gap: 1.4rem; flex-wrap: wrap; justify-content: center; opacity: 0; animation: bfc-rise 1s var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 0.7s both; }
  @keyframes bfc-kenburns { to { transform: scale(1); } }
  @keyframes bfc-rise { from { opacity: 0; transform: translateY(36px); } to { opacity: 1; transform: none; } }
  @media (prefers-reduced-motion: reduce) {
    .bfc-hero__photo { animation: none; transform: none; }
    .bfc-hero__logo, .bfc-hero__cta, .bfc-hero__meta { animation: none; opacity: 1; }
    .bfc-hero__tag .line-inner { transform: none; transition: none; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var tag = document.querySelector('.bfc-hero__tag');
    if (!tag) return;
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      tag.classList.add('is-visible');
      return;
    }
    function split(el) {
      var tokens = [];
      el.childNodes.forEach(function (node) {
        if (node.nodeType === 3) {
          node.textContent.split(/\s+/).filter(Boolean).forEach(function (w) { tokens.push(w); });
        } else if (node.nodeType === 1) {
          tokens.push(node);
        }
      });
      el.textContent = '';
      var wordSpans = tokens.map(function (t) {
        var s = document.createElement('span');
        s.style.display = 'inline-block';
        if (typeof t === 'string') s.textContent = t; else s.appendChild(t);
        el.appendChild(s);
        el.appendChild(document.createTextNode(' '));
        return s;
      });
      var lines = [], lastTop = null;
      wordSpans.forEach(function (s) {
        var top = s.offsetTop;
        if (top !== lastTop) { lines.push([]); lastTop = top; }
        lines[lines.length - 1].push(s);
      });
      if (!lines.length) return;
      el.textContent = '';
      lines.forEach(function (words, i) {
        var line = document.createElement('span');
        line.className = 'line';
        var inner = document.createElement('span');
        inner.className = 'line-inner';
        inner.style.setProperty('--line-i', i);
        words.forEach(function (w, j) {
          w.style.display = 'inline';
          inner.appendChild(w);
          if (j < words.length - 1) inner.appendChild(document.createTextNode(' '));
        });
        line.appendChild(inner);
        el.appendChild(line);
      });
    }
    function run() {
      split(tag);
      requestAnimationFrame(function () {
        requestAnimationFrame(function () { tag.classList.add('is-visible'); });
      });
    }
    if (document.fonts && document.fonts.ready) document.fonts.ready.then(run); else run();
  })();
{% endjavascript %}

{% schema %}
{
  "name": "BFC Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background photo", "info": "Defaults to hero-powder.webp" },
    { "type": "image_picker", "id": "logo", "label": "Logo", "info": "Defaults to logo-web4.webp" },
    { "type": "text", "id": "cta1_label", "label": "Primary button label", "default": "Shop the Range" },
    { "type": "url", "id": "cta1_link", "label": "Primary button link", "info": "Defaults to the all-products collection" },
    { "type": "text", "id": "cta2_label", "label": "Secondary button label", "default": "Our Story" },
    { "type": "url", "id": "cta2_link", "label": "Secondary button link", "info": "Defaults to #manifesto" },
    { "type": "header", "content": "Floating badges" },
    { "type": "text", "id": "badge_left", "label": "Left badge", "default": "Single Origin", "info": "Leave blank to hide. Hidden on mobile." },
    { "type": "text", "id": "badge_right", "label": "Right badge", "default": "Lab Tested", "info": "Leave blank to hide. Hidden on mobile." }
  ],
  "presets": [{ "name": "BFC Hero" }]
}
{% endschema %}
