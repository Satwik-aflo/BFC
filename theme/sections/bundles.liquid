{% comment %}
  Boring Foods — Bundles ("Blends With a Purpose").
  Brand bundle cards (framed photo + Indian-Blue dotted label) on a
  Neem-Green section. Block-driven so the merchant controls each bundle's
  image, name, composition subtitle, and link. Purely presentational.
{% endcomment %}
<section class="bfc-bundles color-{{ section.settings.color_scheme }}" id="bundles">
  <div class="bfc-bundles__inner">
    <div class="bfc-bundles__head">
      {% if section.settings.kicker != blank %}
        <span class="bfc-kicker">{{ section.settings.kicker }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        {%- comment -%}
          Accent the trailing two words in Musloner script.
          Uses a separate accent_phrase setting (optional). When set, renders
          "main_phrase <span class='bfc-accent'>accent_phrase</span>".
          When blank, renders the heading unstyled as a safe fallback.
        {%- endcomment -%}
        {%- if section.settings.heading_accent != blank -%}
          <h2 class="bfc-bundles__title">{{ section.settings.heading }} <span class="bfc-accent">{{ section.settings.heading_accent }}</span></h2>
        {%- else -%}
          <h2 class="bfc-bundles__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
      {% endif %}
    </div>
    <div class="bfc-bundles__grid">
      {% for block in section.blocks %}
        <div class="bfc-bundle-card" {{ block.shopify_attributes }}>
          <a
            class="bfc-bundle-card__link"
            {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
          >
            <div class="bfc-bundle-card__media">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300, 600, 900', alt: block.settings.title }}
              {% elsif block.settings.image_asset != blank %}
                <img src="{{ block.settings.image_asset | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="600" height="600">
              {% endif %}
            </div>
            <div class="bfc-bundle-card__label">
              {% if block.settings.title != blank %}
                <h3 class="bfc-bundle-card__name">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.subtitle != blank %}
                <p class="bfc-bundle-card__sub">{{ block.settings.subtitle }}</p>
              {% endif %}
            </div>
          </a>
          {%- if block.settings.product != blank -%}
            {% render 'bfc-card-commerce', product: block.settings.product, show_weight: false %}
          {%- endif -%}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .bfc-bundles {
    background: var(--color-background);
    color: var(--color-foreground);
    padding: var(--space-4) var(--gutter) var(--space-6);
  }
  .bfc-bundles__inner { max-width: 72rem; margin: 0 auto; }
  .bfc-bundles__head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 0.75rem;
    margin-bottom: var(--space-5);
  }
  .bfc-bundles__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-2xl);
    text-transform: uppercase;
    line-height: 1.15;
    margin: 0;
  }
  .bfc-bundles__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1rem, 2.5vw, 2rem);
  }
  .bfc-bundle-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    height: 100%;
  }
  .bfc-bundle-card__link {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    /* Fill the card so the price + add-to-cart pin to the bottom and align
       across the row no matter how many lines the title/subtitle wrap to. */
    flex: 1 1 auto;
    color: inherit;
    text-decoration: none;
    transition: transform 0.35s var(--bfc-ease-out);
  }
  .bfc-bundle-card__link:hover { transform: translateY(-4px); }
  .bfc-bundle-card__media {
    overflow: hidden;
    border: 1px solid rgb(0 0 0 / 0.35);
    border-radius: 12px;
    aspect-ratio: 1;
    background: var(--kulfi-malai);
  }
  .bfc-bundle-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--bfc-ease-out);
  }
  .bfc-bundle-card__link:hover .bfc-bundle-card__media img { transform: scale(1.05); }
  .bfc-bundle-card__label {
    position: relative;
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.4rem;
    text-align: center;
    background: var(--indian-blue);
    color: var(--kulfi-malai);
    border: var(--bfc-line);
    border-radius: 14px;
    padding: 1.05rem 0.95rem;
    transition: box-shadow 0.35s var(--bfc-ease-out);
  }
  .bfc-bundle-card__label::before {
    content: "";
    position: absolute;
    inset: 7px;
    border: 1.6px dotted rgb(251 243 204 / 0.7);
    border-radius: 8px;
    pointer-events: none;
  }
  .bfc-bundle-card__link:hover .bfc-bundle-card__label { box-shadow: 5px 5px 0 var(--kohl-black); }
  .bfc-bundle-card__name {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: var(--text-sm);
    line-height: 1.3;
    margin: 0;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }
  .bfc-bundle-card__sub {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: var(--text-xs);
    line-height: 1.3;
    margin: 0;
    /* Full cream (no opacity): cream-on-Indian-Blue = 5.18:1 (AA).
       The previous 0.85 opacity dropped it to #e3dccb = 4.22:1 (fail). */
    opacity: 1;
  }
  /* Commerce (price + add-to-cart) on bundle cards */
  .bfc-bundle-card .bfc-card-commerce {
    margin-top: 0.5rem;
  }
  .bfc-bundle-card .bfc-card-pricewt {
    color: var(--kulfi-malai);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.02em;
    text-align: center;
    margin: 0 0 0.5rem;
  }
  .bfc-bundle-card .bfc-card-atc__button {
    width: 100%;
    text-align: center;
  }
  @media (max-width: 900px) {
    .bfc-bundles__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .bfc-bundle-card__name { font-size: 12px; letter-spacing: 0; }
    .bfc-bundle-card__sub { font-size: 10.5px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Bundles",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-neem"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Shop by Benefits"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Blends With"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent (script font)",
      "info": "Words rendered in the Musloner script accent font, appended after heading. Leave blank to disable accent.",
      "default": "a Purpose"
    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_asset", "label": "Image (theme asset filename)", "info": "Fallback when no image is picked above, e.g. bundle-immune-defense.webp" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "subtitle", "label": "Composition / weight" },
        { "type": "product", "id": "product", "label": "Linked product (for price + add to cart)" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundles",
      "blocks": [
        { "type": "bundle" },
        { "type": "bundle" },
        { "type": "bundle" },
        { "type": "bundle" }
      ]
    }
  ]
}
{% endschema %}
