{% comment %}
  Boring Foods — Bundles ("Blends With a Purpose").
  Brand bundle cards (framed photo + Indian-Blue dotted label) on a
  Neem-Green section. Block-driven so the merchant controls each bundle's
  image, name, composition subtitle, and link. Purely presentational.
{% endcomment %}
<section class="bfc-bundles color-{{ section.settings.color_scheme }}" id="bundles">
  <div class="bfc-bundles__inner">
    <div class="bfc-bundles__head">
      {% if section.settings.kicker != blank %}
        <span class="bfc-kicker">{{ section.settings.kicker }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="bfc-bundles__title">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>
    <div class="bfc-bundles__grid">
      {% for block in section.blocks %}
        <a
          class="bfc-bundle-card"
          {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
          {{ block.shopify_attributes }}
        >
          <div class="bfc-bundle-card__media">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300, 600, 900', alt: block.settings.title }}
            {% elsif block.settings.image_asset != blank %}
              <img src="{{ block.settings.image_asset | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="600" height="600">
            {% endif %}
          </div>
          <div class="bfc-bundle-card__label">
            {% if block.settings.title != blank %}
              <h3 class="bfc-bundle-card__name">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.subtitle != blank %}
              <p class="bfc-bundle-card__sub">{{ block.settings.subtitle }}</p>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .bfc-bundles {
    background: var(--color-background);
    color: var(--color-foreground);
    padding: var(--space-7) var(--gutter);
  }
  .bfc-bundles__inner { max-width: 72rem; margin: 0 auto; }
  .bfc-bundles__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    margin-bottom: var(--space-5);
  }
  .bfc-bundles__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-2xl);
    text-transform: uppercase;
    line-height: 1.15;
    margin: 0;
  }
  .bfc-bundles__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1rem, 2.5vw, 2rem);
  }
  .bfc-bundle-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    height: 100%;
    color: inherit;
    text-decoration: none;
    transition: transform 0.35s var(--bfc-ease-out);
  }
  .bfc-bundle-card:hover { transform: translateY(-4px); }
  .bfc-bundle-card__media {
    overflow: hidden;
    border: 1px solid rgb(0 0 0 / 0.35);
    border-radius: 12px;
    aspect-ratio: 1;
    background: var(--kulfi-malai);
  }
  .bfc-bundle-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--bfc-ease-out);
  }
  .bfc-bundle-card:hover .bfc-bundle-card__media img { transform: scale(1.05); }
  .bfc-bundle-card__label {
    position: relative;
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.4rem;
    text-align: center;
    background: var(--indian-blue);
    color: var(--kulfi-malai);
    border: var(--bfc-line);
    border-radius: 14px;
    padding: 1.05rem 0.95rem;
    transition: box-shadow 0.35s var(--bfc-ease-out);
  }
  .bfc-bundle-card__label::before {
    content: "";
    position: absolute;
    inset: 7px;
    border: 1.6px dotted rgb(251 243 204 / 0.7);
    border-radius: 8px;
    pointer-events: none;
  }
  .bfc-bundle-card:hover .bfc-bundle-card__label { box-shadow: 5px 5px 0 var(--kohl-black); }
  .bfc-bundle-card__name {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: var(--text-sm);
    line-height: 1.3;
    margin: 0;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }
  .bfc-bundle-card__sub {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: var(--text-xs);
    line-height: 1.3;
    margin: 0;
    opacity: 0.85;
  }
  @media (max-width: 900px) {
    .bfc-bundles__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .bfc-bundle-card__name { font-size: 12px; letter-spacing: 0; }
    .bfc-bundle-card__sub { font-size: 10.5px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Bundles",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-neem"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Shop by Benefits"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Blends With a Purpose"
    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_asset", "label": "Image (theme asset filename)", "info": "Fallback when no image is picked above, e.g. bundle-immune-defense.jpg" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "subtitle", "label": "Composition / weight" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundles",
      "blocks": [
        { "type": "bundle" },
        { "type": "bundle" },
        { "type": "bundle" },
        { "type": "bundle" }
      ]
    }
  ]
}
{% endschema %}
