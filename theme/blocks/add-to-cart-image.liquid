{% liquid
  assign product = closest.product
  assign variant = product.selected_or_first_available_variant
  
  assign settings = section.settings
  if block
    assign settings = block.settings
  endif

  assign has_second_image = false
  if product.media[1] != blank and product.media[1].media_type == 'image'
    assign has_second_image = true
  endif
%}

<div class="stamp-product-card" style="--gap: {{ settings.product_card_gap }}px;">
  
  <div class="spc-image-container">
    <a href="{{ product.url }}" class="spc-image-link {% if has_second_image %}hover-enabled{% endif %}">
      {% if product.featured_image %}
        
        {{ product.featured_image | image_url: width: 800 | image_tag: class: 'spc-img spc-primary', loading: 'lazy' }}

        {% if has_second_image %}
           {{ product.media[1] | image_url: width: 800 | image_tag: class: 'spc-img spc-secondary', loading: 'lazy' }}
        {% endif %}

      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'spc-img placeholder' }}
      {% endif %}
    </a>

    {%- comment -%} --- ADD TO CART BUTTON (Hover Only) --- {%- endcomment -%}
    {% if variant.available %}
      <form method="post" action="/cart/add" class="spc-atc-form">
        <input type="hidden" name="id" value="{{ variant.id }}">
        <button type="submit" class="spc-atc-btn" aria-label="Add to cart">
          
          {%- if settings.cart_icon_image != blank -%}
            {{ settings.cart_icon_image | image_url: width: 60 | image_tag: class: 'spc-custom-icon', loading: 'lazy' }}
          {%- else -%}
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="21" r="1"></circle>
              <circle cx="20" cy="21" r="1"></circle>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
          {%- endif -%}

        </button>
      </form>
    {% endif %}
    {%- comment -%} --- END ADD TO CART --- {%- endcomment -%}

  </div>

  <div class="spc-stamp-container">
    
    <div class="spc-stamp-bg">
      {% if settings.stamp_image != blank %}
        {{ settings.stamp_image | image_url: width: 600 | image_tag: class: 'spc-stamp-img', loading: 'lazy' }}
      {% else %}
        <div class="spc-css-stamp"></div>
      {% endif %}
    </div>

    <div class="spc-content">
      <h3 class="spc-title">
        <a href="{{ product.url }}">{{ product.title }}</a>
      </h3>
      {% if variant.weight > 0 %}
        <p class="spc-weight">{{ variant.weight }} G</p>
      {% endif %}
    </div>

  </div>

</div>

<style>
  /* --- Card Container --- */
  .stamp-product-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap, 10px);
    width: 100%;
    font-family: sans-serif; 
  }

  /* --- Image Section --- */
  .spc-image-container {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 0 5px; 
    position: relative; /* Needed for positioning the ATC button */
  }

  .spc-image-link {
    position: relative;
    display: block;
    width: 100%;
    max-width: 400px; 
    height: auto;
    aspect-ratio: 1 / 1.3; 
  }

  /* --- Images --- */
  .spc-img {
    width: 100%;
    height: 100%;
    object-fit: contain; 
    display: block;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .spc-primary {
    position: absolute;
    top: 0; 
    left: 0;
    z-index: 1;
    opacity: 1;
  }

  .spc-secondary {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    opacity: 0;
  }

  /* --- Hover Effects --- */
  .stamp-product-card:hover .spc-img {
    transform: scale(1.02);
  }

  .spc-image-link.hover-enabled:hover .spc-primary {
    opacity: 0;
  }

  .spc-image-link.hover-enabled:hover .spc-secondary {
    opacity: 1;
  }

  /* --- Add To Cart Button Styles --- */
  .spc-atc-form {
    position: absolute;
    bottom: 15px;
    right: 15px;
    z-index: 10;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s ease;
    pointer-events: none;
  }

  .stamp-product-card:hover .spc-atc-form {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .spc-atc-btn {
    appearance: none;
    -webkit-appearance: none;
    background: #ffffff; 
    border: 2px solid #000;
    border-radius: 50%;
    width: 45px;
    height: 45px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #000;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: background 0.2s, transform 0.2s;
    padding: 0; /* Remove default padding for image fit */
    overflow: hidden; /* Ensures image stays inside circle */
  }

  .spc-atc-btn:hover {
    background: #f0f0f0;
    transform: scale(1.1);
  }

  /* Style for default SVG */
  .spc-atc-btn svg {
    width: 20px;
    height: 20px;
  }

  /* Style for Custom Uploaded Image */
  .spc-custom-icon {
    width: 100%;
    height: 100%;
    object-fit: cover; /* Covers the whole button area */
    display: block;
  }

  /* --- Stamp Section --- */
  .spc-stamp-container {
    position: relative;
    width: 100%;
    min-height: 120px; 
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    text-align: center;
  }

  .spc-stamp-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .spc-stamp-img {
    width: 100%;
    height: 100%;
    object-fit: fill; 
  }

  .spc-css-stamp {
    width: 100%;
    height: 100%;
    background-color: #5A56B3; 
    border: 4px dotted #FBF3CC; 
    box-shadow: 0 0 0 4px #5A56B3; 
    border-radius: 4px;
  }

  /* --- Text Content --- */
.spc-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
  align-items: center;
  width: 100%;
  padding-inline: 8px;
}

.spc-title {
  margin: 0;
  font-weight: 800;
  line-height: 1.1;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  color: #FFFFFF;
  text-align: center;
  font-size: clamp(0.65rem, 2.6vw, 0.9rem);
}

.spc-title a {
  text-decoration: none;
  color: inherit;
}

.spc-weight {
  margin: 0;
  font-weight: 700;
  color: #FFFFFF;
  text-transform: uppercase;
  opacity: 0.9;
  text-align: center;
  font-size: clamp(0.7rem, 2.1vw, 0.9rem);
}

</style>

{% schema %}
{
  "name": "t:names.product_card",
  "settings": [
    {
      "type": "paragraph",
      "content": "Custom Stamp Design"
    },
    {
      "type": "range",
      "id": "product_card_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "image_picker",
      "id": "stamp_image",
      "label": "Stamp Background Image",
      "info": "Upload the purple stamp shape (PNG with transparency)."
    },
    {
      "type": "header",
      "content": "Add to Cart Button"
    },
    {
      "type": "image_picker",
      "id": "cart_icon_image",
      "label": "Cart Button Icon",
      "info": "Upload a custom icon or image. If empty, a default icon is used."
    }
  ]
}
{% endschema %}