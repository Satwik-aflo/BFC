  :root {
    --font-body--family: "Aesthet Nova", Georgia, serif;
    --font-subheading--family: "Copperplate BFC", "Aesthet Nova", serif;
    --font-heading--family: "Copperplate BFC", Georgia, serif;
    --font-accent--family: "Flagflies", "Copperplate BFC", serif;
    /* Brand-only families for charm/script/poster accents (sections opt in). */
    --font-charm: "Flagflies", Georgia, serif;
    --font-script: "Musloner", cursive;
    --font-poster: "Mexicana Hollow", "Copperplate BFC", serif;
    --font-display: var(--font-heading--family);

    /* Brand palette + scale tokens (mirror site/css/tokens.css) so our custom
       sections can reuse the static-site CSS almost verbatim. New var names
       only — they never override Horizon's own color or font-family vars. */
    --kulfi-malai: #fbf3cc;
    --indian-blue: #5d57c5;
    --ripe-orange: #f84b21;
    --ripe-orange-ink: #c2390f; /* AA-safe orange for small text on cream */
    --mango-yellow: #f9bf29;
    --neem-green: #244f24;
    --kohl-black: #000000;
    --kulfi-deep: #f6ebb4;
    --ink-soft: rgba(0, 0, 0, 0.72);

    --text-xs: 0.75rem;
    --text-sm: 0.875rem;
    --text-base: 1.0625rem;
    --text-lg: 1.3125rem;
    --text-xl: clamp(1.5rem, 1.2rem + 1.4vw, 2.25rem);
    --text-2xl: clamp(2rem, 1.4rem + 2.6vw, 3.5rem);
    --text-3xl: clamp(2.75rem, 1.8rem + 4.5vw, 5.5rem);
    --text-poster: clamp(3.5rem, 2rem + 9vw, 11rem);

    --tracking-caps: 0.18em;
    --tracking-wide: 0.32em;
    --leading-body: 1.65;
    --bfc-line: 1.5px solid var(--kohl-black);
    --bfc-ease-out: cubic-bezier(0.22, 1, 0.36, 1);

    --space-1: 0.5rem;
    --space-2: 1rem;
    --space-3: 1.5rem;
    --space-4: 2.5rem;
    --space-5: 4rem;
    --space-6: 6.5rem;
    --space-7: 10rem;
    --gutter: clamp(1.25rem, 4vw, 4rem);
    --measure: 38rem;
  }
