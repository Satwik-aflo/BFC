{% comment %}
  Boring Foods brand layer.
  Loads the custom brand fonts and overrides Horizon's four base font-family
  variables so all type (h1-h6, paragraphs, subheadings, accents, buttons, cart)
  inherits the brand typography. Rendered after 'color-schemes' in theme.liquid.
  Purely additive - no core Horizon files are altered.
{% endcomment %}
{% style %}
  @font-face {
    font-family: "Aesthet Nova";
    src: url({{ 'AesthetNova-Light.woff2' | asset_url }}) format("woff2"), url({{ 'AesthetNova-Light.otf' | asset_url }}) format("opentype");
    font-weight: 300;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Aesthet Nova";
    src: url({{ 'AesthetNova-Medium.woff2' | asset_url }}) format("woff2"), url({{ 'AesthetNova-Medium.otf' | asset_url }}) format("opentype");
    font-weight: 400 500;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Aesthet Nova";
    src: url({{ 'AesthetNova-Black.woff2' | asset_url }}) format("woff2"), url({{ 'AesthetNova-Black.otf' | asset_url }}) format("opentype");
    font-weight: 600 900;
    font-style: normal;
    font-display: swap;
  }
  /* Hyphenated aliases the live comparison table forces by name. */
  @font-face {
    font-family: "Aesthet-Nova-Light";
    src: url({{ 'AesthetNova-Light.woff2' | asset_url }}) format("woff2"), url({{ 'AesthetNova-Light.otf' | asset_url }}) format("opentype");
    font-weight: 300;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Aesthet-Nova";
    src: url({{ 'AesthetNova-Medium.woff2' | asset_url }}) format("woff2"), url({{ 'AesthetNova-Medium.otf' | asset_url }}) format("opentype");
    font-weight: 400 700;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Aesthet-Nova-Medium";
    src: url({{ 'AesthetNova-Medium.woff2' | asset_url }}) format("woff2"), url({{ 'AesthetNova-Medium.otf' | asset_url }}) format("opentype");
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Copperplate BFC";
    src: url({{ 'Copperplate-Light.woff2' | asset_url }}) format("woff2"), url({{ 'Copperplate-Light.otf' | asset_url }}) format("opentype");
    font-weight: 300;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Copperplate BFC";
    src: url({{ 'Copperplate-Regular.woff2' | asset_url }}) format("woff2"), url({{ 'Copperplate-Regular.otf' | asset_url }}) format("opentype");
    font-weight: 400 500;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Copperplate BFC";
    src: url({{ 'Copperplate-Heavy.woff2' | asset_url }}) format("woff2"), url({{ 'Copperplate-Heavy.otf' | asset_url }}) format("opentype");
    font-weight: 600 900;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Flagflies";
    src: url({{ 'Flagflies.woff2' | asset_url }}) format("woff2"), url({{ 'Flagflies.ttf' | asset_url }}) format("truetype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Musloner";
    src: url({{ 'Musloner.woff2' | asset_url }}) format("woff2"), url({{ 'Musloner.otf' | asset_url }}) format("opentype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Mexicana Hollow";
    src: url({{ 'MexicanaHollow.woff2' | asset_url }}) format("woff2"), url({{ 'MexicanaHollow.ttf' | asset_url }}) format("truetype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --font-body--family: "Aesthet Nova", Georgia, serif;
    --font-subheading--family: "Copperplate BFC", "Aesthet Nova", serif;
    --font-heading--family: "Copperplate BFC", Georgia, serif;
    --font-accent--family: "Flagflies", "Copperplate BFC", serif;
    /* Brand-only families for charm/script/poster accents (sections opt in). */
    --font-charm: "Flagflies", Georgia, serif;
    --font-script: "Musloner", cursive;
    --font-poster: "Mexicana Hollow", "Copperplate BFC", serif;
    --font-display: var(--font-heading--family);

    /* Brand palette + scale tokens (mirror site/css/tokens.css) so our custom
       sections can reuse the static-site CSS almost verbatim. New var names
       only — they never override Horizon's own color or font-family vars. */
    --kulfi-malai: #fbf3cc;
    --indian-blue: #5d57c5;
    --ripe-orange: #f84b21;
    --ripe-orange-ink: #c2390f; /* AA-safe orange for small text on cream */
    --mango-yellow: #f9bf29;
    --neem-green: #244f24;
    --kohl-black: #000000;
    --kulfi-deep: #f6ebb4;
    --ink-soft: rgba(0, 0, 0, 0.72);

    --text-xs: 0.75rem;
    --text-sm: 0.875rem;
    --text-base: 1.0625rem;
    --text-lg: 1.3125rem;
    --text-xl: clamp(1.5rem, 1.2rem + 1.4vw, 2.25rem);
    --text-2xl: clamp(2rem, 1.4rem + 2.6vw, 3.5rem);
    --text-3xl: clamp(2.75rem, 1.8rem + 4.5vw, 5.5rem);
    --text-poster: clamp(3.5rem, 2rem + 9vw, 11rem);

    --tracking-caps: 0.18em;
    --tracking-wide: 0.32em;
    --leading-body: 1.65;
    --bfc-line: 1.5px solid var(--kohl-black);
    --bfc-ease-out: cubic-bezier(0.22, 1, 0.36, 1);

    --space-1: 0.5rem;
    --space-2: 1rem;
    --space-3: 1.5rem;
    --space-4: 2.5rem;
    --space-5: 4rem;
    --space-6: 6.5rem;
    --space-7: 10rem;
    --gutter: clamp(1.25rem, 4vw, 4rem);
    --measure: 38rem;
  }

  /* ── Brand utility classes (shared by our custom sections) ──────────── */
  .bfc-kicker {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.85em;
  }
  .bfc-kicker::before,
  .bfc-kicker::after {
    content: "";
    width: 2.5rem;
    height: 1px;
    background: currentColor;
    opacity: 0.5;
  }
  .bfc-caps {
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
  }
  .bfc-script { font-family: var(--font-script); }
  .bfc-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.7em;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--kohl-black);
    background: var(--mango-yellow);
    border: var(--bfc-line);
    outline: 1px solid var(--kohl-black);
    outline-offset: 3px;
    padding: 0.9em 1.6em;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.25s var(--bfc-ease-out), box-shadow 0.25s var(--bfc-ease-out);
  }
  .bfc-btn .hand { font-size: 1.2em; line-height: 0; transform: translateY(-1px); }
  .bfc-btn:hover { transform: translate(-2px, -2px); box-shadow: 4px 4px 0 var(--kohl-black); }
  .bfc-btn:active { transform: translate(0, 0); box-shadow: none; }
  .bfc-btn--light { background: var(--kulfi-malai); }

  /* ── Navigation legibility ──────────────────────────────────────────
     Copperplate is an engraved (airy) face, so the top-level nav needs a
     heavier weight + letter-spacing to read well. Horizon also dims
     non-hovered links via --opacity-subdued-text and, on hover, swaps the
     header's --color-foreground to `inherit` (which makes the rgb()-based
     link colour resolve to nothing -> the text vanishes). We pin explicit,
     high-contrast colours and force full opacity in every state. */
  .menu-list__link,
  .menu-list__link:hover,
  .menu-list__link:focus,
  .menu-list:where(:has(.menu-list__list-item:hover)) .menu-list__link,
  .menu-list:where(:has(.menu-list__list-item:focus-within)) .menu-list__link {
    opacity: 1 !important;
    font-weight: 700;
    /* Static site: nav links are 12px / 0.18em tracking (--text-xs). Horizon
       defaults this far larger; pin it small so the bar reads quiet + premium
       and sits into the photo rather than shouting over it. */
    font-size: 0.75rem !important;
    letter-spacing: 0.18em;
  }

  /* Static-site header parity: 58px logo + roomier nav (static gap = 2.4rem).
     The logo is an SVG so it scales crisply; Horizon renders it at 36px. */
  .header-logo__image {
    height: clamp(48px, 4vw, 58px) !important;
    width: auto !important;
    max-width: none;
  }
  .header__column--center .menu-list { gap: clamp(1.8rem, 2.6vw, 2.4rem); }

  /* Issue 2: the compact header packs the logo flush against the promo bar.
     Give the header's top row a little vertical breathing room so the logo
     (and nav) sit a few px below the announcement bar, on every page. */
  .header__row--top { padding-block-start: 6px; }

  /* Issue 4: the navigation-bar second row (.header__navigation-bar-row →
     .menu-list--mobile) renders the menu inline on mobile and lands on top of
     the hero. Hide it on mobile so the menu lives only in the hamburger drawer;
     the top row keeps the hamburger, search, account and cart. */
  @media (max-width: 749px) {
    .header__navigation-bar-row { display: none !important; }
  }

  /* Solid headers (sub-pages): always render nav in Kohl Black on the
     cream/scheme background, regardless of Horizon's hover colour swap. */
  header-component:not([transparent]) .menu-list__link,
  header-component:not([transparent]) .menu-list__link:hover,
  header-component:not([transparent]) .menu-list__link:focus,
  header-component:not([transparent]) .menu-list:where(:has(.menu-list__list-item:hover)) .menu-list__link {
    color: #000 !important;
  }

  /* Transparent header (over the hero photo): render nav in Kulfi cream (not
     the scheme's cold near-white) with a TIGHT offset shadow so the type sits
     INTO the photo like the static site, instead of a wide blur that haloes. */
  header-component[transparent] .menu-list__link,
  header-component[transparent] .menu-list__link:hover,
  header-component[transparent] .menu-list__link:focus {
    color: var(--kulfi-malai) !important;
    text-shadow: 0 1px 2px rgb(0 0 0 / 0.6), 0 1px 4px rgb(0 0 0 / 0.35);
  }

  /* Home: once the transparent header gains its solid (cream) background on
     scroll, the [transparent] cream-nav rule above renders cream-on-cream —
     invisible. Horizon never removes the [transparent] attribute; instead it
     sets data-sticky-state="active" when the header sticks after scrolling.
     Force dark nav + action icons in that scrolled/stuck state.
     Selector confirmed live via DOM inspection (Step 1). */
  header-component[data-sticky-state="active"] .menu-list__link {
    color: #000 !important;
    text-shadow: none !important;
  }
  /* Action icons (search / account / cart): darken to the SAME tone Horizon uses
     for solid-header icons on sub-pages (rgba(0,0,0,0.81)), and do NOT touch
     `fill` — forcing fill:currentColor turned these line icons into solid black
     blobs (the scroll-state icon regression). Colour drives their stroke. */
  header-component[data-sticky-state="active"] :is(.header-actions__action, .header__icon) {
    color: rgba(0, 0, 0, 0.81) !important;
    text-shadow: none !important;
  }

  /* Submenu / overflow dropdown links: ensure they never inherit a dimmed
     or transparent colour. */
  .menu-list__submenu .menu-list__link,
  .overflow-menu .menu-list__link {
    opacity: 1 !important;
    color: var(--color-foreground) !important;
  }

  /* ── Announcement bar (promo / discount-code attention bar) ─────────
     Keep the Indian-Blue scheme-4 bar but tune it to the brand: tighter
     Copperplate caps, and a gentle opacity fade-in on load. NOTE: this used
     to be a translateY slide-down, but a transform on the topmost element
     skews its getBoundingClientRect while Horizon / the transparent hero
     header measure their offsets on load — which cramped the header, logo
     and hero centering until the first scroll forced a recalculation (and
     the late-loading brand CSS made the bar paint once, then slide, looking
     doubled). A pure opacity fade keeps layout geometry stable and reads
     cleaner. The BORING10 code is marked with <em> (see header-group.json —
     inline_richtext strips spans, but allows <em>) to read as a Mango-Yellow
     chip. */
  .announcement-bar {
    animation: bfc-promo-fade 0.8s var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) both;
  }
  .announcement-bar__text {
    letter-spacing: 0.14em;
    text-transform: uppercase;
    /* Single-line from first paint — the long promo would otherwise wrap to
       ~3 lines, then collapse the instant the marquee script runs (a visible
       height jump on load). Locking the bar to one line up front keeps the
       header offset stable and degrades to a readable truncated line if JS
       never runs. width:100% caps the <p> to its container so overflow:hidden
       clips (instead of the nowrap line ballooning past the viewport).
       !important: Horizon's compiled .text-block paragraph rule (0,1,1) loads
       after this snippet and outranks a plain .announcement-bar__text (0,1,0),
       so the single-line lock needs to win the cascade explicitly. */
    white-space: nowrap !important;
    overflow: hidden !important;
    width: 100%;
    text-align: center;
  }
  /* BORING10 chip — scope to .announcement-bar (not __text) so it still styles
     the <em> after the marquee script nests the copy inside a track. */
  .announcement-bar em {
    display: inline-block;
    font-style: normal;
    background: var(--mango-yellow);
    color: var(--kohl-black);
    font-weight: 700;
    letter-spacing: 0.12em;
    padding: 0.05em 0.5em;
    border-radius: 4px;
    margin: 0 0.15em;
    box-shadow: 1px 1px 0 rgb(0 0 0 / 0.45);
  }

  /* Marquee ticker (chosen via the /prototype pass). The promo copy scrolls
     horizontally instead of wrapping to 4 lines (~145px) on mobile — keeps the
     full message, stays ~40px, and a single-line bar holds a stable height from
     first paint (no wrap-reflow that destabilised the header offset on load).
     The script at the end of this file nests the announcement copy into a
     two-copy track; translateX(-50%) loops it seamlessly. */
  .announcement-bar.bfc-marquee-on .announcement-bar__slides {
    max-width: none;
    width: 100%;
  }
  .announcement-bar.bfc-marquee-on .announcement-bar__slide { width: 100%; }
  .announcement-bar.bfc-marquee-on .announcement-bar__text {
    width: 100%;
  }
  .bfc-marquee__track {
    display: inline-flex;
    will-change: transform;
    animation: bfc-marquee 22s linear infinite;
  }
  .announcement-bar.bfc-marquee-on:hover .bfc-marquee__track,
  .announcement-bar.bfc-marquee-on:focus-within .bfc-marquee__track {
    animation-play-state: paused;
  }
  .bfc-marquee__item { padding-inline-end: 3rem; white-space: nowrap; }
  @keyframes bfc-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes bfc-promo-fade {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .announcement-bar { animation: none; }
    .bfc-marquee__track { animation: none; }
  }

  /* Issue 9: the judge.me featured carousel forces each slide to a fixed
     height (~200px) and stretches the review body to the tallest review, so the
     reviewer name is stranded far below short reviews and each slide carries
     dead space (long mobile scroll). On mobile, collapse the slide + review to
     natural content height so reviews are compact and the name sits directly
     under the text. Desktop keeps equal heights for its side-by-side reviews.
     `!important` beats judge.me's non-important inline heights. */
  @media (max-width: 749px) {
    .jdgm-carousel-item,
    .jdgm-carousel-item__review {
      height: auto !important;
      min-height: 0 !important;
    }
  }

  /* ── Global accessibility (audit items #8, #10) ─────────────────────
     High-contrast focus ring (Indian Blue) so brand styling never
     suppresses keyboard focus; wrap long Copperplate/Mexicana headings
     so they don't clip at 360px. */
  :where(a, button, summary, input, select, textarea, [tabindex]):focus-visible {
    outline: 2px solid #5d57c5;
    outline-offset: 2px;
    border-radius: 2px;
  }
  h1, h2, h3, h4,
  .h0, .h1, .h2, .h3, .h4 {
    overflow-wrap: break-word;
    hyphens: auto;
  }

  /* ── Brand product cards ────────────────────────────────────────────
     Reskin Horizon's native <product-card> (used on the homepage Shop
     grid, collection/PLP, search results, recommendations) into the brand
     card: the content panel becomes the Indian-Blue label with an inset
     dotted cream border, a framed photo, and cream Copperplate name +
     price. Price is kept (restyled), per product decision. Logic untouched. */
  .product-card { transition: transform 0.35s var(--bfc-ease-out); }
  .product-card:hover { transform: translateY(-4px); }
  .product-card .product-card__content {
    position: relative;
    background: var(--indian-blue) !important;
    color: var(--kulfi-malai) !important;
    border: var(--bfc-line);
    border-radius: 14px;
    padding: 0.9rem;
    text-align: center;
    gap: 0.6rem;
    transition: box-shadow 0.35s var(--bfc-ease-out);
  }
  .product-card:hover .product-card__content { box-shadow: 5px 5px 0 var(--kohl-black); }
  .product-card .product-card__content::before {
    content: "";
    position: absolute;
    inset: 7px;
    border: 1.6px dotted rgb(251 243 204 / 0.7);
    border-radius: 9px;
    pointer-events: none;
    z-index: 3;
  }
  .product-card .product-card__content :is(.product-media, .media, img, svg) {
    border-radius: 10px;
  }
  .product-card .product-card__content img {
    transition: transform 0.8s var(--bfc-ease-out);
  }
  .product-card:hover .product-card__content img { transform: scale(1.05); }
  .product-card .product-card__content :is(h1, h2, h3, h4, h5, h6, a, .price, .price *) {
    color: var(--kulfi-malai) !important;
    font-family: var(--font-heading--family);
  }
  .product-card .product-card__content :is(h1, h2, h3, h4, h5, h6) {
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.3;
    overflow-wrap: anywhere;
    text-wrap: balance;
  }

  /* ── Search + cart reskin → match static .sf-search / .sf-cart ───────
     Panels are already cream via popover_color_scheme / drawer_color_scheme
     = scheme-1. These rules port the static mock's brand treatment onto
     Horizon's native components. CSS only — search/cart logic, forms, and
     markup are 100% untouched. Static reference: site/css/main.css 1207-1442. */

  /* Cart-count bubble: Ripe-Orange chip, cream Copperplate count. */
  .cart-bubble__background {
    background: var(--ripe-orange) !important;
    border: 1px solid var(--kohl-black);
  }
  .cart-bubble__text {
    color: var(--kulfi-malai) !important;
    font-family: var(--font-display);
    font-weight: 700;
  }

  /* Primary CTAs → static .btn (= .bfc-btn): mango-yellow, black text,
     double black border, Copperplate uppercase, hover lift + hard shadow.
     Applies to checkout, predictive "View all", and the empty-cart button. */
  #checkout.cart__checkout-button,
  .predictive-search__search-button,
  .cart-items__empty-button {
    font-family: var(--font-display) !important;
    font-weight: 700 !important;
    letter-spacing: var(--tracking-caps) !important;
    text-transform: uppercase !important;
    color: var(--kohl-black) !important;
    background: var(--mango-yellow) !important;
    border: var(--bfc-line) !important;
    outline: 1px solid var(--kohl-black);
    outline-offset: 3px;
    border-radius: 0 !important;
    box-shadow: none;
    transition: transform 0.25s var(--bfc-ease-out), box-shadow 0.25s var(--bfc-ease-out);
  }
  #checkout.cart__checkout-button:hover,
  .predictive-search__search-button:hover,
  .cart-items__empty-button:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--kohl-black);
  }
  #checkout.cart__checkout-button { width: 100%; justify-content: center; }
  .cart__checkout-button .button-text { color: var(--kohl-black) !important; }
  .predictive-search-form__footer { display: flex; justify-content: center; }

  /* Cart drawer / page headings → Copperplate uppercase. */
  .cart-drawer__summary {
    background: var(--kulfi-deep);
    border-top: var(--bfc-line);
  }
  .cart-drawer__heading,
  .cart-drawer__header .h4 {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
  }

  /* Line items → static .sf-line. */
  .cart-items__title {
    font-family: var(--font-display) !important;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .cart-items__media-container img,
  .cart-items__media img {
    border: var(--bfc-line);
    background: var(--kulfi-deep);
    border-radius: 0;
  }
  .cart-items__variant,
  .cart-items__variants {
    color: var(--ink-soft);
    font-size: var(--text-xs);
  }
  .cart-items__quantity-controls {
    border: 1px solid var(--kohl-black);
    border-radius: 999px;
    overflow: hidden;
  }
  .cart-items__quantity-controls button:hover,
  .cart-items__quantity-controls .quantity-selector__button:hover {
    color: var(--ripe-orange);
  }
  .cart-items__remove {
    color: var(--ink-soft) !important;
    text-underline-offset: 3px;
  }
  .cart-items__remove:hover { color: var(--ripe-orange) !important; }
  .cart-items__price {
    font-family: var(--font-display);
    font-weight: 700;
  }

  /* Totals → static .sf-cart__subtotal. */
  .cart-totals__total-label,
  .cart-totals__original-label {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
  }
  .cart-totals__total,
  .cart-totals__total-value {
    font-family: var(--font-display);
    font-weight: 700;
  }

  /* Empty states → static charm/neem-green. */
  .cart-drawer__heading--empty {
    font-family: var(--font-charm);
    text-transform: none;
    letter-spacing: normal;
    color: var(--neem-green);
  }

  /* ── Search modal → static full-width top-sliding panel (.sf-search). ──
     Re-anchors Horizon's centered cmdk modal into the static site's panel that
     slides down from the top of the viewport. Keeps Horizon's predictive search,
     empty-state product grid (Recently Viewed + Products), focus trap,
     scroll-lock and keyboard. CSS only — no markup/JS touched.
     Static ref: site/css/main.css 1207-1291 + /tmp/bfc-qa/ss_desk_open_final.png. */

  /* Shell: full-width, pinned to viewport top, cream, black underline, inner 64rem. */
  .search-modal__content {
    position: fixed !important;
    inset: 0 0 auto 0 !important;
    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;
    padding: clamp(1.25rem, 4vw, 2.25rem) var(--gutter) clamp(2rem, 5vw, 3rem) !important;
    background: var(--kulfi-malai) !important;
    border: none !important;
    border-bottom: var(--bfc-line) !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    max-height: 85dvh;
    overflow: hidden;
  }
  .search-modal__content[open] { display: block !important; }
  .search-modal__content predictive-search-component {
    display: block !important;
    width: 100%;
    max-width: 64rem;
    margin-inline: auto;
    background: transparent !important;
  }
  /* Visible "SEARCH" title — un-hide Horizon's modal heading (static .sf-search__title). */
  .search-modal__content #search-modal-heading {
    position: static !important;
    width: auto !important;
    height: auto !important;
    margin: 0 auto 1rem !important;
    padding: 0 !important;
    clip: auto !important;
    clip-path: none !important;
    overflow: visible !important;
    white-space: normal !important;
    max-width: 64rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--kohl-black);
  }

  /* Slide down from the top (static: translateY(-100%)→0, 0.5s brand ease-out). */
  @keyframes bfc-search-slide-down {
    from { transform: translateY(-100%); }
    to   { transform: translateY(0); }
  }
  @keyframes bfc-search-slide-up {
    from { transform: translateY(0); }
    to   { transform: translateY(-100%); }
  }
  .dialog-modal[open].search-modal__content {
    transform-origin: top center !important;
    animation: bfc-search-slide-down 0.5s var(--bfc-ease-out) forwards !important;
    border-radius: 0 !important;
    box-shadow: none !important;
  }
  .dialog-modal.search-modal__content.dialog-closing {
    animation: bfc-search-slide-up 0.35s var(--bfc-ease-out) forwards !important;
  }
  @media (prefers-reduced-motion: reduce) {
    .dialog-modal[open].search-modal__content,
    .dialog-modal.search-modal__content.dialog-closing {
      animation: none !important;
    }
  }

  /* Dimming scrim on every breakpoint (Horizon hides ::backdrop under 750px). */
  .search-modal__content::backdrop { background: rgba(0, 0, 0, 0.38); }
  @media screen and (max-width: 749px) {
    .search-modal__content::backdrop { display: block; }
  }

  /* Field: single black underline (no boxed border), big body-font input. */
  .search-modal__content .predictive-search-form__header,
  .search-modal__content .predictive-search-form__header-inner {
    background: transparent !important;
    border: none !important;
    border-radius: 0 !important;
    box-shadow: none !important;
  }
  .search-modal__content .predictive-search-form__header {
    border-bottom: var(--bfc-line) !important;
    padding: 0 !important;
  }
  .search-modal__content :is(.search-input, input[type="search"], .predictive-search-form__input) {
    font-size: clamp(1.25rem, 1rem + 2vw, 2rem) !important;
    font-family: var(--font-body--family);
    font-weight: 500;
    color: var(--kohl-black);
  }

  /* Mobile: the brand body font at clamp(~24px) clips the long placeholder
     ("Search our boring little pantry"). Drop to 16px (iOS no-zoom floor) so the
     full placeholder is visible. */
  @media (max-width: 749px) {
    .search-modal__content :is(.search-input, input[type="search"], .predictive-search-form__input) {
      font-size: 1rem !important;
    }
  }

  /* Results + empty-state grid flow INSIDE the panel and scroll there
     (Horizon hangs them off the input as an absolute dropdown). */
  .search-modal__content .predictive-search-form__content-wrapper {
    position: static !important;
    top: auto;
    width: 100%;
    max-height: none !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    overflow: visible;
  }
  .search-modal__content .predictive-search-form__content {
    max-height: min(60dvh, 32rem) !important;
    overflow-y: auto;
    background: transparent !important;
    padding-block-start: 1.25rem;
  }
  .search-modal__content .predictive-search-form__footer {
    position: static !important;
    background: none !important;
    padding-block: 1.25rem 0 !important;
  }

  /* Empty-state + predictive result TYPE (kept from Wave 1c — matches the
     user-approved official grid: green Copperplate section titles, uppercase
     product names, WCAG-safe orange prices). */
  .predictive-search-results__title {
    font-family: var(--font-display) !important;
    font-weight: 700;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--neem-green);
  }
  .predictive-search-results__card .resource-card__title {
    font-family: var(--font-display) !important;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .predictive-search-results__card :is(.resource-card__subtext, .price, .price *) {
    color: var(--ripe-orange-ink) !important;
  }

  /* Focus ring (don't suppress Horizon's; make it brand + high-contrast). */
  .search-modal__content :is(input, button, a):focus-visible,
  .cart-drawer__dialog :is(input, button, a):focus-visible,
  .cart-page__summary :is(input, button, a):focus-visible {
    outline: 2px solid var(--ripe-orange-ink);
    outline-offset: 2px;
  }

  /* Touch: keep cart stepper / remove ≥44px (WCAG 2.5.5). */
  @media (pointer: coarse) {
    .cart-items__quantity-controls button { min-width: 44px; min-height: 44px; }
    .cart-items__remove { min-height: 44px; }
  }

  /* Batch 3: product-card price + net weight inline (₹289 / 150 g) + add-to-cart-only (no buy-now).
     Rendered via snippets/bfc-card-commerce.liquid as a custom-liquid block in the product-card. */
  .bfc-card-commerce { margin-block-start: 0.4rem; }
  .bfc-card-pricewt {
    margin: 0 0 0.5rem;
    font-family: var(--font-heading--family);
    font-weight: 700;
    color: var(--kulfi-malai);
  }
  .bfc-card-weight { font-size: 0.8em; opacity: 0.75; white-space: nowrap; }
  .bfc-card-atc { display: block; }
  /* Centre the retro-oval pill (it is an inline-block, content-width button). */
  .bfc-card-atc,
  .bfc-card-atc form { text-align: center; }

  /* ── Retro-oval add-to-cart pill (mirrors the live PDP button: purple oval,
     yellow caps, chunky shadow, two star sparkles). Classes are unique to our
     card buttons, so these rules don't touch any other button. ── */
  .retro-oval-wrapper {
    position: relative;
    display: inline-block;
    width: auto;
    max-width: 100%;
    z-index: 1;
    vertical-align: middle;
  }
  .button-retro-oval,
  .button-retro-oval:disabled[disabled] {
    --retro-purple: #6a69e2;
    --retro-yellow: #fefeb0;
    --retro-dark: #222222;
    background-color: var(--retro-purple) !important;
    color: var(--retro-yellow) !important;
    border: 3px solid var(--retro-dark) !important;
    border-radius: 400px !important;
    box-shadow: 0 6px 0 var(--retro-dark) !important;
    font-family: var(--font-heading--family) !important;
    font-weight: 800 !important;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 14px 30px;
    width: auto !important;
    min-width: 0 !important;
    max-width: 100%;
    display: inline-block !important;
    opacity: 1 !important;
    position: relative;
    transition: transform 0.1s ease-in-out, box-shadow 0.1s ease-in-out;
  }
  .button-retro-oval:not(:disabled):hover {
    transform: translateY(4px);
    box-shadow: 0 2px 0 var(--retro-dark) !important;
  }
  .button-retro-oval:not(:disabled):active {
    transform: translateY(6px);
    box-shadow: none !important;
  }
  .retro-sparkle {
    position: absolute;
    z-index: 2;
    pointer-events: none;
    width: 42px;
    height: auto;
  }
  .sparkle-top-left { top: -19px; left: -13px; }
  .sparkle-bottom-right { bottom: -15px; right: -13px; }

  /* Card add-to-cart "added" state (mirrors the PDP button: cart icon → checkmark + "Added").
     Scoped to card buttons; PDP / quick-add keep their own snippet behaviour. */
  .bfc-card-atc__button .add-to-cart-text--added {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
  }
  .bfc-card-atc__button[data-added='true'] .add-to-cart-text { display: none; }
  .bfc-card-atc__button[data-added='true'] .add-to-cart-text--added { display: inline-flex; }
  .bfc-card-atc__button .svg-wrapper svg { width: 1.05em; height: 1.05em; }

  /* Bottom-align the price + add-to-cart across a row of homepage product cards,
     regardless of how many lines the title wraps to. Horizon already gives
     .product-card { display:grid; height:100% } so .product-card__content fills the
     row; we just push our commerce block's (class-less) wrapper to the bottom. */
  .product-card__content:has(.bfc-card-commerce) { height: 100%; }
  .product-card__content > *:has(> .bfc-card-commerce) { margin-block-start: auto; }

  /* ── Batch 4: tighten homepage section headings to 1–2 lines, smaller. ──
     The Horizon core text-block headings ("Boring Foods, Your Way" and
     "How We Are Different") are plain <h2> elements with no custom class —
     we target them via their shopify-section ID attribute. The bundles and
     judge.me headings have their own classes. CSS only for Horizon-core
     headings; markup accent-span added to bundles.liquid (our section). */

  /* "Boring Foods, Your Way" (product_list_wE8meU) and "How We Are Different"
     (section_PWFkyK): NO size override — they inherit the Horizon default so
     they match the "Socials" h2 (section_HmpREz: 48px, Copperplate, ripe-orange)
     along with their shared stars icon. (User: match these to the Socials h2.) */

  /* "Blends With a Purpose" — our bundles section (.bfc-bundles__title).
     Desktop: was ~56px (1 line). Target: ~38px, 1 line.
     Mobile: was ~33px → 2 lines. Target: ~26px → 1-2 lines.
     .bfc-accent span (added in bundles.liquid) takes Musloner script font. */
  .bfc-bundles__title {
    font-size: clamp(1.6rem, 1.2rem + 2.2vw, 2.4rem) !important;
    line-height: 1.12 !important;
    text-wrap: balance !important;
    overflow-wrap: break-word !important;
  }
  /* Accent span: trailing phrase in Musloner script. */
  .bfc-bundles__title .bfc-accent {
    font-family: var(--font-script) !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
    font-size: 1.2em !important;
    display: inline !important;
  }

  /* "Let customers speak for us" — judge.me carousel title (third-party).
     Was 40px at both breakpoints → 1 line desktop, 2 lines mobile.
     Target: ~22px at mobile so it stays 1 line; ~28px desktop. */
  .jdgm-carousel-title {
    font-size: clamp(1.2rem, 0.9rem + 1.8vw, 1.75rem) !important;
    line-height: 1.2 !important;
    text-wrap: balance !important;
    overflow-wrap: break-word !important;
  }
{% endstyle %}

{%- comment -%}
  Announcement-bar marquee: nest the promo copy into a two-copy track so the CSS
  ticker (.bfc-marquee__track in the brand styles above) loops seamlessly. Keeps
  Horizon's announcement section/block pristine — this only reshapes the rendered
  text node. No-op if the bar is missing or already initialised.
{%- endcomment -%}
<script>
  (function () {
    function initMarquee(root) {
      var bar = (root || document).querySelector('.announcement-bar');
      if (!bar || bar.classList.contains('bfc-marquee-on')) return;
      var textEl = bar.querySelector('.announcement-bar__text');
      if (!textEl) return;
      var html = textEl.innerHTML.trim();
      if (!html) return;
      textEl.innerHTML =
        '<span class="bfc-marquee__track">' +
          '<span class="bfc-marquee__item">' + html + '</span>' +
          '<span class="bfc-marquee__item" aria-hidden="true">' + html + '</span>' +
        '</span>';
      bar.classList.add('bfc-marquee-on');
    }
    if (document.readyState !== 'loading') initMarquee();
    else document.addEventListener('DOMContentLoaded', function () { initMarquee(); });
    document.addEventListener('shopify:section:load', function (e) { initMarquee(e.target); });
  })();
</script>
