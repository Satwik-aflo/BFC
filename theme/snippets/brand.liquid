{% comment %}
  Boring Foods brand layer (orchestrator).
  Loads the brand fonts and overrides Horizon's four base font-family variables
  so all type (h1-h6, paragraphs, subheadings, accents, buttons, cart) inherits
  the brand typography, plus targeted component fixes. Rendered after
  'color-schemes' in theme.liquid so it wins the cascade.

  The CSS lives in snippets/brand-*.liquid partials, rendered below IN SOURCE
  ORDER inside ONE inline {% style %} block (so asset_url resolves for @font-face
  and the emitted CSS is identical to the former monolith). Order is load-bearing
  — do not reorder these renders. Purely additive; no core Horizon files altered.
{% endcomment %}
{% style %}
  {%- render 'brand-fonts-and-tokens' -%}
  {%- render 'brand-utilities' -%}
  {%- render 'brand-header-nav' -%}
  {%- render 'brand-announcement' -%}
  {%- render 'brand-a11y' -%}
  {%- render 'brand-product-cards' -%}
  {%- render 'brand-cart-search' -%}
  {%- render 'brand-card-commerce' -%}
  {%- render 'brand-page-headings' -%}
{% endstyle %}

{%- comment -%}
  Announcement-bar marquee: nest the promo copy into a two-copy track so the CSS
  ticker (.bfc-marquee__track in the brand styles above) loops seamlessly. Keeps
  Horizon's announcement section/block pristine — this only reshapes the rendered
  text node. No-op if the bar is missing or already initialised.
{%- endcomment -%}
<script>
  (function () {
    function initMarquee(root) {
      var bar = (root || document).querySelector('.announcement-bar');
      if (!bar || bar.classList.contains('bfc-marquee-on')) return;
      var textEl = bar.querySelector('.announcement-bar__text');
      if (!textEl) return;
      var html = textEl.innerHTML.trim();
      if (!html) return;
      textEl.innerHTML =
        '<span class="bfc-marquee__track">' +
          '<span class="bfc-marquee__item">' + html + '</span>' +
          '<span class="bfc-marquee__item" aria-hidden="true">' + html + '</span>' +
        '</span>';
      bar.classList.add('bfc-marquee-on');
    }
    if (document.readyState !== 'loading') initMarquee();
    else document.addEventListener('DOMContentLoaded', function () { initMarquee(); });
    document.addEventListener('shopify:section:load', function (e) { initMarquee(e.target); });
  })();
</script>
