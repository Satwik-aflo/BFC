{% doc %}
  Renders price + net weight and an add-to-cart-only control (NO buy-now) for a product card.
  @param {object} product - The card's product.
  @param {boolean} [show_weight] - Set to false to hide the weight (e.g. on bundle cards where weight is in the subtitle). Defaults to true.
{% enddoc %}
{%- liquid
  assign v = product.selected_or_first_available_variant
  assign form_id = 'bfc-atc-' | append: product.id
-%}
<div class="bfc-card-commerce">
  <p class="bfc-card-pricewt">{{ v.price | money }}{%- if show_weight != false -%}<span class="bfc-card-weight"> / {{ v.weight | round }} {{ v.weight_unit }}</span>{%- endif -%}</p>
  <product-form-component data-product-id="{{ product.id }}" on:submit="/handleSubmit" class="bfc-card-atc">
    {%- form 'product', product, id: form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
      <input type="hidden" name="id" value="{{ v.id }}"{% if v.available == false %} disabled{% endif %}>
      <input type="hidden" name="quantity" value="1">
      {%- assign atc_media = v.featured_media.preview_image | default: product.featured_media.preview_image | image_url: width: 100 -%}
      <add-to-cart-component
        ref="addToCartButtonContainer"
        data-product-variant-media="{{ atc_media }}"
        data-add-to-cart-animation="{{ settings.add_to_cart_animation }}"
      >
        <button
          type="submit"
          name="add"
          ref="addToCartButton"
          on:click="/handleClick"
          class="button bfc-card-atc__button"
          {% if v.available == false %}disabled{% endif %}
        >
          <span class="add-to-cart-text">
            <span aria-hidden="true" class="svg-wrapper add-to-cart-icon">
              {{- 'icon-add-to-cart.svg' | inline_asset_content -}}
            </span>
            <span class="add-to-cart-text__content">Add to cart</span>
          </span>
          <span aria-hidden="true" class="add-to-cart-text--added">
            <span class="svg-wrapper add-to-cart-icon--added">
              {{- 'icon-checkmark.svg' | inline_asset_content -}}
            </span>
            <span>Added</span>
          </span>
        </button>
      </add-to-cart-component>
    {%- endform -%}
  </product-form-component>
</div>
