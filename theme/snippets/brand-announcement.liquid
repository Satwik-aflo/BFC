{% doc %}
  Brand layer partial: announcement promo bar + marquee CSS/keyframes. Rendered inside the single {% style %} block in
  snippets/brand.liquid (in source order). CSS only.
{% enddoc %}
  /* ── Announcement bar (promo / discount-code attention bar) ─────────
     Keep the Indian-Blue scheme-4 bar but tune it to the brand: tighter
     Copperplate caps, and a gentle opacity fade-in on load. NOTE: this used
     to be a translateY slide-down, but a transform on the topmost element
     skews its getBoundingClientRect while Horizon / the transparent hero
     header measure their offsets on load — which cramped the header, logo
     and hero centering until the first scroll forced a recalculation (and
     the late-loading brand CSS made the bar paint once, then slide, looking
     doubled). A pure opacity fade keeps layout geometry stable and reads
     cleaner. The BORING10 code is marked with an em element (see header-group.json —
     inline_richtext strips spans, but allows an em element) to read as a Mango-Yellow
     chip. */
  .announcement-bar {
    animation: bfc-promo-fade 0.8s var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) both;
  }
  .announcement-bar__text {
    letter-spacing: 0.14em;
    text-transform: uppercase;
    /* Single-line from first paint — the long promo would otherwise wrap to
       ~3 lines, then collapse the instant the marquee script runs (a visible
       height jump on load). Locking the bar to one line up front keeps the
       header offset stable and degrades to a readable truncated line if JS
       never runs. width:100% caps the the p element to its container so overflow:hidden
       clips (instead of the nowrap line ballooning past the viewport).
       !important: Horizon's compiled .text-block paragraph rule (0,1,1) loads
       after this snippet and outranks a plain .announcement-bar__text (0,1,0),
       so the single-line lock needs to win the cascade explicitly. */
    white-space: nowrap !important;
    overflow: hidden !important;
    width: 100%;
    text-align: center;
  }
  /* BORING10 chip — scope to .announcement-bar (not __text) so it still styles
     the an em element after the marquee script nests the copy inside a track. */
  .announcement-bar em {
    display: inline-block;
    font-style: normal;
    background: var(--mango-yellow);
    color: var(--kohl-black);
    font-weight: 700;
    letter-spacing: 0.12em;
    padding: 0.05em 0.5em;
    border-radius: 4px;
    margin: 0 0.15em;
    box-shadow: 1px 1px 0 rgb(0 0 0 / 0.45);
  }

  /* Marquee ticker (chosen via the /prototype pass). The promo copy scrolls
     horizontally instead of wrapping to 4 lines (~145px) on mobile — keeps the
     full message, stays ~40px, and a single-line bar holds a stable height from
     first paint (no wrap-reflow that destabilised the header offset on load).
     The script at the end of this file nests the announcement copy into a
     two-copy track; translateX(-50%) loops it seamlessly. */
  .announcement-bar.bfc-marquee-on .announcement-bar__slides {
    max-width: none;
    width: 100%;
  }
  .announcement-bar.bfc-marquee-on .announcement-bar__slide { width: 100%; }
  .announcement-bar.bfc-marquee-on .announcement-bar__text {
    width: 100%;
  }
  .bfc-marquee__track {
    display: inline-flex;
    will-change: transform;
    animation: bfc-marquee 22s linear infinite;
  }
  .announcement-bar.bfc-marquee-on:hover .bfc-marquee__track,
  .announcement-bar.bfc-marquee-on:focus-within .bfc-marquee__track {
    animation-play-state: paused;
  }
  .bfc-marquee__item { padding-inline-end: 3rem; white-space: nowrap; }
  @keyframes bfc-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes bfc-promo-fade {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .announcement-bar { animation: none; }
    .bfc-marquee__track { animation: none; }
  }

  /* Issue 9: the judge.me featured carousel forces each slide to a fixed
     height (~200px) and stretches the review body to the tallest review, so the
     reviewer name is stranded far below short reviews and each slide carries
     dead space (long mobile scroll). On mobile, collapse the slide + review to
     natural content height so reviews are compact and the name sits directly
     under the text. Desktop keeps equal heights for its side-by-side reviews.
     `!important` beats judge.me's non-important inline heights. */
  @media (max-width: 749px) {
    .jdgm-carousel-item,
    .jdgm-carousel-item__review {
      height: auto !important;
      min-height: 0 !important;
    }
  }
