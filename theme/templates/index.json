{
  "sections": {
    "custom_liquid_CjPRme": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<section class=\"bfc-hero\" id=\"top\">\n  <div class=\"bfc-hero__media\" aria-hidden=\"true\">\n    <img class=\"bfc-hero__photo\" src=\"{{ 'hero-powder.jpg' | asset_url }}\" alt=\"\" loading=\"eager\">\n    <div class=\"bfc-hero__scrim\"></div>\n  </div>\n  <aside class=\"bfc-hero__meta bfc-hero__meta--left bfc-caps\">Single<br>Origin</aside>\n  <aside class=\"bfc-hero__meta bfc-hero__meta--right bfc-caps\">Lab<br>Tested</aside>\n  <img class=\"bfc-hero__logo\" src=\"{{ 'logo-web4.png' | asset_url }}\" alt=\"The Boring Foods Company\" width=\"340\" height=\"190\">\n  <p class=\"bfc-hero__tag\">In a world of synthetic, flashy health fads, we bring you back to the basics &mdash; <span class=\"bfc-script\">boring,</span> powerful, time-tested foods.</p>\n  <div class=\"bfc-hero__cta\">\n    <a class=\"bfc-btn\" href=\"{{ routes.all_products_collection_url }}\"><span class=\"hand\">&#9758;</span> Shop the Range</a>\n    <a class=\"bfc-btn bfc-btn--light\" href=\"#manifesto\"><span class=\"hand\">&#9758;</span> Our Story</a>\n  </div>\n</section>\n<style>\n  .bfc-hero{min-height:100svh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;position:relative;padding:7rem var(--gutter) 8rem;color:var(--kulfi-malai);overflow:hidden}\n  .bfc-hero__media{position:absolute;inset:0;z-index:0;overflow:hidden}\n  .bfc-hero__photo{width:100%;height:100%;object-fit:cover}\n  .bfc-hero__scrim{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,.45) 0%,rgba(0,0,0,.12) 35%,rgba(0,0,0,.08) 60%,rgba(0,0,0,.4) 100%)}\n  .bfc-hero>:not(.bfc-hero__media){position:relative;z-index:1}\n  .bfc-hero__meta{position:absolute;top:50%;transform:translateY(-50%);font-size:var(--text-xs);font-weight:700;line-height:1.7;color:var(--kohl-black);background:var(--mango-yellow);padding:.8em 1.2em;z-index:2}\n  .bfc-hero__meta--left{left:var(--gutter);text-align:left}\n  .bfc-hero__meta--right{right:var(--gutter);text-align:right}\n  .bfc-hero__logo{width:clamp(200px,26vw,340px);height:auto;margin-bottom:var(--space-4)}\n  .bfc-hero__tag{margin-top:var(--space-2);font-size:var(--text-xl);font-weight:500;line-height:1.45;max-width:44rem}\n  .bfc-hero__tag .bfc-script{font-size:1.25em}\n  .bfc-hero__cta{margin-top:var(--space-4);display:flex;gap:1.4rem;flex-wrap:wrap;justify-content:center}\n  @media (max-width:600px){.bfc-hero__meta{display:none}}\n</style>",
        "color_scheme": "scheme-1",
        "section_width": "full-width"
      }
